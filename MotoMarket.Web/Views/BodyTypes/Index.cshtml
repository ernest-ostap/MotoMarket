@model IEnumerable<MotoMarket.Web.Models.DTOs.DictionaryDto>
@{
    ViewData["Title"] = "Typy Nadwozia";
}

<div class="container mt-4 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-2">
                <i class="bi bi-car-front text-primary me-2"></i>Typy Nadwozia
            </h2>
            <p class="text-muted mb-0">Zarządzaj typami nadwozia w systemie</p>
        </div>
        <a asp-controller="BodyTypes" asp-action="Create" class="btn btn-success btn-lg">
            <i class="bi bi-plus-circle me-1"></i>Dodaj nowy
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card shadow-lg border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">ID</th>
                            <th>Nazwa</th>
                            <th width="200px">Status</th>
                            <th width="200px" class="text-end pe-4">Akcje</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4">@item.Id</td>
                                <td><strong>@item.Name</strong></td>
                                <td>
                                    <form asp-action="ToggleActive" asp-route-id="@item.Id" method="post" style="display:inline;">
                                        @if (item.IsActive)
                                        {
                                            <button type="submit" class="btn badge bg-success border-0" title="Kliknij, aby ukryć">
                                                <i class="bi bi-check-circle me-1"></i>Widoczny
                                            </button>
                                        }
                                        else
                                        {
                                            <button type="submit" class="btn badge bg-secondary border-0" title="Kliknij, aby aktywować">
                                                <i class="bi bi-x-circle me-1"></i>Ukryty
                                            </button>
                                        }
                                    </form>
                                </td>
                                <td class="text-end pe-4">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning me-2" title="Edytuj">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <form asp-action="Delete" asp-route-id="@item.Id" method="post" style="display:inline;" onsubmit="return confirm('Czy na pewno usunąć?');">
                                        <button type="submit" class="btn btn-sm btn-danger" title="Usuń">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="mt-4">
        <a asp-controller="Admin" asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i>Wróć do Panelu
        </a>
    </div>
</div>

