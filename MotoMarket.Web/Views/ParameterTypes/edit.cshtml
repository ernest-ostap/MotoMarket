@model MotoMarket.Web.Models.DTOs.ParameterTypeDto
@{
    ViewData["Title"] = "Edytuj Parametr";
}

<div class="container mt-5" style="max-width: 600px;">
    <div class="card shadow">
        <div class="card-header bg-warning text-dark">
            <h5 class="mb-0">Edytuj parametr</h5>
        </div>
        <div class="card-body">
            <form asp-action="Edit" method="post">
                
                <input type="hidden" asp-for="Id" />

                <div class="row mb-3">
                    <div class="col-md-8">
                        <label class="form-label">Nazwa parametru</label>
                        <input asp-for="Name" class="form-control" required />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Jednostka</label>
                        <input asp-for="Unit" class="form-control" />
                        <span asp-validation-for="Unit" class="text-danger"></span>
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-md-6">
                        <label class="form-label">Kategoria</label>
                        <input asp-for="Category" class="form-control" list="categories" required />
                        <datalist id="categories">
                            <option value="Silnik" />
                            <option value="Nadwozie" />
                            <option value="Ogólne" />
                            <option value="Wymiary" />
                        </datalist>
                        <span asp-validation-for="Category" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Typ danych</label>
                        <select asp-for="InputType" class="form-select">
                            <option value="number">Liczba</option>
                            <option value="text" selected>Tekst</option>
                        </select>
                    </div>
                </div>

                <div class="mb-4">
                    <div class="form-check form-switch">
                        <input asp-for="IsRequired" class="form-check-input" type="checkbox" id="reqCheck" />
                        <label class="form-check-label" for="reqCheck">Czy parametr jest wymagany?</label>
                    </div>
                </div>

                <div class="d-grid gap-2">
                    <button type="submit" class="btn btn-warning">Zaktualizuj</button>
                    <a asp-action="Index" class="btn btn-link text-decoration-none text-secondary">Anuluj</a>
                </div>
            </form>
        </div>
    </div>
</div>
