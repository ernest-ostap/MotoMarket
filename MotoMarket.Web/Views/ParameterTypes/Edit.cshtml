@model MotoMarket.Web.Models.DTOs.ParameterTypeDto

@{
    ViewData["Title"] = "Edytuj Typ Parametru";
}

<div class="container mt-5" style="max-width: 600px;">
    <div class="card shadow">
        <div class="card-header bg-warning text-dark">
            Edytuj Typ Parametru
        </div>
        <div class="card-body">
            <form asp-action="Edit" method="post">

                <input type="hidden" asp-for="Id" />

                <div class="mb-3">
                    <label class="form-label">Kategoria</label>
                    <input asp-for="Category" class="form-control" list="categories" placeholder="np. Silnik" required />

                    <datalist id="categories">
                        <option value="Silnik" />
                        <option value="Wymiary" />
                        <option value="Paliwo" />
                        <option value="Skrzynia biegów" />
                        <option value="Inne" />
                    </datalist>
                    <span asp-validation-for="Category" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label">Nazwa</label>
                    <input asp-for="Name" class="form-control" required />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label">Jednostka</label>
                    <input asp-for="Unit" class="form-control" placeholder="np. KM, l, kg" />
                    <span asp-validation-for="Unit" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label">Typ wejścia</label>
                    <select asp-for="InputType" class="form-select" required>
                        <option value="">Wybierz typ</option>
                        <option value="number">Liczba</option>
                        <option value="text">Tekst</option>
                        <option value="select">Lista wyboru</option>
                    </select>
                    <span asp-validation-for="InputType" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <div class="form-check">
                        <input type="checkbox" asp-for="IsRequired" class="form-check-input" id="isRequired" />
                        <label class="form-check-label" for="isRequired">Wymagany</label>
                    </div>
                </div>

                <div class="d-grid gap-2">
                    <button type="submit" class="btn btn-warning">Zaktualizuj</button>
                    <a asp-action="Index" class="btn btn-link text-decoration-none text-secondary">Anuluj</a>
                </div>
            </form>
        </div>
    </div>
</div>

