@model MotoMarket.Web.Models.DTOs.ModelDto
@{
    ViewData["Title"] = "Edytuj Model";
}

<div class="container mt-4 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow-lg border-0">
                <div class="card-header bg-warning text-dark py-4">
                    <h4 class="mb-0 fw-bold">
                        <i class="bi bi-pencil-square me-2"></i>Edytuj Model
                    </h4>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Edit" method="post">
                        <input type="hidden" asp-for="Id" />
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Marka *</label>
                            <select asp-for="BrandId" class="form-select" required>
                                @foreach (var brand in ViewBag.Brands)
                                {
                                    <option value="@brand.Id">@brand.Name</option>
                                }
                            </select>
                        </div>
                        <div class="mb-4">
                            <label class="form-label fw-semibold">Nazwa Modelu *</label>
                            <input asp-for="Name" class="form-control" required />
                        </div>
                        <div class="d-flex justify-content-between align-items-center pt-3 border-top">
                            <a asp-action="Index" class="btn btn-outline-secondary">
                                <i class="bi bi-arrow-left me-1"></i>Anuluj
                            </a>
                            <button type="submit" class="btn btn-warning btn-lg px-4">
                                <i class="bi bi-check-lg me-2"></i>Zaktualizuj
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>