@model MotoMarket.Web.Models.DTOs.ModelDto
@{
    ViewData["Title"] = "Edytuj Model";
}

<div class="container mt-5" style="max-width: 500px;">
    <div class="card shadow">
        <div class="card-header bg-warning text-dark">Edytuj Model</div>
        <div class="card-body">
            <form asp-action="Edit" method="post">
                <input type="hidden" asp-for="Id" />

                <div class="mb-3">
                    <label class="form-label">Marka</label>
                    <select asp-for="BrandId" class="form-select" required>
                        @foreach (var brand in ViewBag.Brands)
                        {
                            <option value="@brand.Id">@brand.Name</option>
                        }
                    </select>
                </div>

                <div class="mb-3">
                    <label class="form-label">Nazwa Modelu</label>
                    <input asp-for="Name" class="form-control" required />
                </div>

                <button type="submit" class="btn btn-warning w-100">Zapisz</button>
            </form>
            <a asp-action="Index" class="btn btn-link d-block text-center mt-2">Anuluj</a>
        </div>
    </div>
</div>