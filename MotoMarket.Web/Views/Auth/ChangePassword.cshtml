@model MotoMarket.Web.Models.ViewModels.ChangePasswordViewModel
@{
    ViewData["Title"] = "Zmiana hasła";
}

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-5 col-lg-4">
            <div class="card shadow-lg border-0">
                <div class="card-header bg-warning text-dark text-center py-4">
                    <h3 class="mb-0 fw-bold">
                        <i class="bi bi-key me-2"></i>Zmiana hasła
                    </h3>
                </div>
                <div class="card-body p-4">
                    @if (TempData["Success"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }
                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            <i class="bi bi-exclamation-circle me-2"></i>@TempData["Error"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }

                    <form asp-action="ChangePassword" method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Obecne hasło</label>
                            <input asp-for="CurrentPassword" class="form-control" type="password" placeholder="Wpisz obecne hasło" />
                            <span asp-validation-for="CurrentPassword" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Nowe hasło</label>
                            <input asp-for="NewPassword" class="form-control" type="password" placeholder="Wpisz nowe hasło" />
                            <span asp-validation-for="NewPassword" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-semibold">Potwierdź nowe hasło</label>
                            <input asp-for="ConfirmNewPassword" class="form-control" type="password" placeholder="Powtórz nowe hasło" />
                            <span asp-validation-for="ConfirmNewPassword" class="text-danger small"></span>
                        </div>

                        <button type="submit" class="btn btn-warning w-100 btn-lg mb-3">
                            <i class="bi bi-key me-2"></i>Zmień hasło
                        </button>
                    </form>
                    <div class="text-center pt-3 border-top">
                        <a asp-controller="Home" asp-action="Index" class="text-muted text-decoration-none">
                            <i class="bi bi-arrow-left me-1"></i>Powrót do strony głównej
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
