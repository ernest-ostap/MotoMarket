@model MotoMarket.Web.Models.ViewModels.RegisterViewModel
@{
    ViewData["Title"] = "Rejestracja";
}

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow-lg border-0">
                <div class="card-header bg-success text-white text-center py-4">
                    <h3 class="mb-0 fw-bold">
                        <i class="bi bi-person-plus me-2"></i>Rejestracja
                    </h3>
                    <p class="mb-0 mt-2 opacity-90">Dołącz do naszej społeczności</p>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Register" method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-semibold">Imię *</label>
                                <input asp-for="FirstName" class="form-control" placeholder="Jan" />
                                <span asp-validation-for="FirstName" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-semibold">Nazwisko *</label>
                                <input asp-for="LastName" class="form-control" placeholder="Kowalski" />
                                <span asp-validation-for="LastName" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Email *</label>
                            <input asp-for="Email" class="form-control" type="email" placeholder="twoj@email.pl" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Numer telefonu</label>
                            <input asp-for="PhoneNumber" class="form-control" placeholder="+48 123 456 789" />
                            <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Hasło *</label>
                            <input asp-for="Password" class="form-control" type="password" placeholder="Minimum 6 znaków" />
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-semibold">Potwierdź hasło *</label>
                            <input asp-for="ConfirmPassword" class="form-control" type="password" placeholder="Powtórz hasło" />
                            <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                        </div>

                        <button type="submit" class="btn btn-success w-100 btn-lg mb-3">
                            <i class="bi bi-person-plus me-2"></i>Zarejestruj się
                        </button>
                    </form>
                    <div class="text-center pt-3 border-top">
                        <p class="mb-0 text-muted">Masz już konto? <a asp-action="Login" class="fw-semibold">Zaloguj się</a></p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>