@model MotoMarket.Web.Models.ViewModels.HomeViewModel
@{
    ViewData["Title"] = "Strona Główna";
}

<div class="bg-dark text-white p-5 mb-5 rounded-3 text-center" style="background-image: url('/images/hero-bg.jpg'); background-size: cover;">
    <div class="container py-5">
        <h1 class="display-4 fw-bold">@Model.WelcomeTitle</h1>
        <p class="fs-4 mb-4">@Model.WelcomeSubtitle</p>

        <div class="card p-3 mx-auto shadow-lg text-dark" style="max-width: 800px; opacity: 0.95;">
            <form asp-controller="Listings" asp-action="Index" method="get" class="row g-2 align-items-end">

                <div class="col-md-4">
                    <label class="form-label text-start d-block small fw-bold">Marka</label>
                    <select name="brandId" class="form-select">
                        <option value="">Wszystkie marki</option>
                        @foreach (var brand in Model.Brands)
                        {
                            <option value="@brand.Id">@brand.Name</option>
                        }
                    </select>
                </div>

                <div class="col-md-4">
                    <label class="form-label text-start d-block small fw-bold">Szukaj</label>
                    <input type="text" name="searchQuery" class="form-control" placeholder="np. Audi A4..." />
                </div>

                <div class="col-md-4">
                    <button type="submit" class="btn btn-danger w-100 fw-bold">
                        <i class="bi bi-search"></i> Znajdź pojazd
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">Najnowsze ogłoszenia 🔥</h2>
        <a asp-controller="Listings" asp-action="Index" class="btn btn-outline-dark">Zobacz wszystkie</a>
    </div>

    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-4 g-4">
        @foreach (var car in Model.RecentListings)
        {
            <div class="col">
                <div class="card h-100 shadow-sm border-0">
                    <img src="@(string.IsNullOrEmpty(car.MainPhotoUrl) ? "https://via.placeholder.com/300x200?text=Brak+zdjęcia" : car.MainPhotoUrl)"
                         class="card-img-top" alt="@car.Title" style="height: 200px; object-fit: cover;">

                    <div class="card-body">
                        <h5 class="card-title text-truncate">@car.Title</h5>
                        <p class="card-text fw-bold text-danger">@car.Price.ToString("N0") PLN</p>
                        <ul class="list-unstyled small text-muted mb-0">
                            <li><i class="bi bi-calendar"></i> @car.ProductionYear • @(car.Mileage / 1000) tys. km</li>
                            <li><i class="bi bi-geo-alt"></i> @car.LocationCity</li>
                        </ul>
                    </div>
                    <div class="card-footer bg-white border-0 pt-0">
                        <a asp-controller="Listings" asp-action="Details" asp-route-id="@car.Id" class="btn btn-outline-primary w-100 btn-sm">
                            Zobacz szczegóły
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>