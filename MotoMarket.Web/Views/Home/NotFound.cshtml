@{
    ViewData["Title"] = "Nie znaleziono";
}

<div class="container d-flex justify-content-center align-items-center" style="min-height: 60vh;">
    <div class="text-center">
        <div class="mb-4">
            <i class="bi bi-search text-warning" style="font-size: 5rem;"></i>
        </div>

        <h1 class="fw-bold mb-3">Strona nie istnieje</h1>

        <p class="lead text-muted mb-4">
            Przykro nam, ale strona, której szukasz (lub ogłoszenie)<br />
            nie została odnaleziona w naszej bazie.
        </p>

        <div class="d-flex justify-content-center gap-3">
            <a asp-controller="Home" asp-action="Index" class="btn btn-primary px-4 py-2">
                <i class="bi bi-house-door me-2"></i>Wróć na główną
            </a>
            <a href="javascript:history.back()" class="btn btn-outline-secondary px-4 py-2">
                <i class="bi bi-arrow-left me-2"></i>Wróć tam gdzie byłeś
            </a>
        </div>
    </div>
</div>