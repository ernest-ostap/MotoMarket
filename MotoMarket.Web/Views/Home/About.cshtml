@model IEnumerable<MotoMarket.Web.Models.DTOs.PageContentDto>
@{
    ViewData["Title"] = "O Nas";
    // Helper do wyciągania tekstu
    string GetContent(string key) => Model.FirstOrDefault(x => x.PageKey == key)?.Content ?? "Brak treści";
}

<div class="container mt-5 mb-5">
    <!-- Hero Section -->
    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold mb-3">@Html.Raw(GetContent("ABOUT_HEADER"))</h1>
        <p class="lead text-muted">Poznaj naszą historię i misję</p>
    </div>

    <!-- Content Section -->
    <div class="row align-items-center mb-5">
        <div class="col-md-6 mb-4 mb-md-0">
            <div class="card shadow-lg border-0 overflow-hidden" style="border-radius: var(--radius-xl);">
                <img src="https://via.placeholder.com/600x400" class="img-fluid" alt="O nas" style="object-fit: cover; height: 400px;">
            </div>
        </div>
        <div class="col-md-6">
            <div class="ps-md-4">
                <h3 class="fw-bold mb-4">
                    <i class="bi bi-info-circle text-primary me-2"></i>Kim jesteśmy?
                </h3>
                <div class="fs-5 text-secondary" style="line-height: 1.8;">
                    @Html.Raw(GetContent("ABOUT_BODY"))
                </div>
            </div>
        </div>
    </div>

    <!-- Contact Section -->
    <div class="card shadow-lg border-0 mt-5">
        <div class="card-body p-5 text-center">
            <div class="mb-4">
                <i class="bi bi-envelope-heart text-primary" style="font-size: 3rem;"></i>
            </div>
            <h3 class="fw-bold mb-3">Skontaktuj się z nami</h3>
            <div class="text-secondary fs-5">
                @Html.Raw(GetContent("CONTACT_INFO"))
            </div>
        </div>
    </div>
</div>