@{
    ViewData["Title"] = "Konto Zablokowane";
}

<div class="container mt-5 text-center">
    <div class="card border-danger shadow-lg mx-auto" style="max-width: 600px;">
        <div class="card-header bg-danger text-white">
            <h3 class="mb-0"><i class="bi bi-slash-circle-fill"></i> Blokada Konta</h3>
        </div>
        <div class="card-body p-5">
            <h1 class="display-1 text-danger mb-4">
                <i class="bi bi-person-x-fill"></i>
            </h1>
            <h4 class="card-title text-danger fw-bold">Twoje konto zostało zawieszone.</h4>
            <p class="card-text lead mt-3">
                Przykro nam, ale dostęp do serwisu został zablokowany przez Administratora z powodu naruszenia regulaminu.
            </p>

            <hr class="my-4">

            <p class="text-muted small">
                Jeśli uważasz, że to pomyłka, skontaktuj się z obsługą klienta.
            </p>

            <a asp-controller="Home" asp-action="Index" class="btn btn-outline-dark mt-3">
                <i class="bi bi-house"></i> Wróć na stronę główną
            </a>
        </div>
    </div>
</div>