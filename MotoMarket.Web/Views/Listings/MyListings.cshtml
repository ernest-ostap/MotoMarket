@using MotoMarket.Web.Models.DTOs
@model IEnumerable<ListingDto>

@{
    ViewData["Title"] = "Moje ogłoszenia";
}

<div class="container mt-4 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-2">
                <i class="bi bi-card-list text-primary me-2"></i>Moje ogłoszenia
            </h2>
            <p class="text-muted mb-0">Zarządzaj swoimi ogłoszeniami</p>
        </div>
        <a asp-action="Create" class="btn btn-primary btn-lg">
            <i class="bi bi-plus-circle me-1"></i>Dodaj nowe
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="card shadow-lg border-0 text-center">
            <div class="card-body p-5">
                <i class="bi bi-inbox text-muted" style="font-size: 4rem;"></i>
                <h4 class="mt-4 mb-3">Nie masz jeszcze żadnych ogłoszeń</h4>
                <p class="text-muted mb-4">Rozpocznij sprzedaż swojego pojazdu już dziś!</p>
                <a asp-action="Create" class="btn btn-primary btn-lg">
                    <i class="bi bi-plus-circle me-1"></i>Dodaj pierwsze ogłoszenie
                </a>
            </div>
        </div>
    }
    else
    {
        <div class="card shadow-lg border-0">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th style="width: 100px;">Zdjęcie</th>
                        <th>Tytuł</th>
                        <th>Cena</th>
                        <th>Data dodania</th>
                        <th>Status</th>
                        <th class="text-end">Akcje</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        var statusLabel = item.Status switch
                        {
                            0 => "Szkic",
                            1 => "Aktywne",
                            2 => "Sprzedane",
                            3 => "Zarchiwizowane",
                            4 => "Zablokowane",
                            _ => "Nieznany"
                        };

                        var statusBadge = item.Status switch
                        {
                            1 => "success",
                            2 => "secondary",
                            3 => "warning",
                            4 => "danger",
                            _ => "info"
                        };

                        <tr class="@(item.Status == 3 ? "table-warning" : "")">
                            <td>
                                @if (!string.IsNullOrEmpty(item.MainPhotoUrl))
                                {
                                    <img src="@item.MainPhotoUrl" alt="Thumb" class="img-thumbnail" style="width: 80px; height: 60px; object-fit: cover;">
                                }
                                else
                                {
                                    <div class="bg-light text-muted d-flex align-items-center justify-content-center" style="width: 80px; height: 60px; font-size: 0.7rem;">Brak</div>
                                }
                            </td>
                            <td>
                                <strong>@item.BrandName @item.ModelName</strong><br />
                                <small class="text-muted">@item.Title</small>
                            </td>
                            <td class="fw-bold text-success">@item.Price.ToString("C0")</td>
                            <td>@item.CreatedAt.ToShortDateString()</td>
                            <td>
                                <span class="badge bg-@statusBadge">@statusLabel</span>
                            </td>
                            <td class="text-end">
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info" title="Podgląd">
                                    👁️
                                </a>

                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning" title="Edytuj">
                                    ✏️
                                </a>

                                @if (item.Status == 1)
                                {
                                    <form asp-action="MarkSold" asp-route-id="@item.Id" method="post" class="d-inline" onsubmit="return confirm('Oznaczyć ogłoszenie jako sprzedane?');">
                                        <button type="submit" class="btn btn-sm btn-outline-secondary" title="Sprzedane">
                                            💰
                                        </button>
                                    </form>
                                }

                                @if (item.Status == 3)
                                {
                                    <form asp-action="Restore" asp-route-id="@item.Id" method="post" class="d-inline" onsubmit="return confirm('Przywrócić ogłoszenie jako aktywne?');">
                                        <button type="submit" class="btn btn-sm btn-outline-success" title="Przywróć">
                                            ♻️
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline" onsubmit="return confirm('Czy na pewno chcesz zarchiwizować to ogłoszenie?');">
                                        <button type="submit" class="btn btn-sm btn-outline-danger" title="Archiwizuj">
                                            🗑️
                                        </button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
                </div>
            </div>
        </div>
    }
</div>