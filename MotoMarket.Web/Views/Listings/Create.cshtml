@model MotoMarket.Web.Models.ViewModels.CreateListingViewModel

@{
    ViewData["Title"] = "Dodaj ogłoszenie";
}

<h2>Nowe ogłoszenie</h2>

<form asp-action="Create" method="post" enctype="multipart/form-data">
    <div class="row">
        <div class="col-md-6 mb-3">
            <label asp-for="BrandId" class="form-label"></label>
            <select asp-for="BrandId" asp-items="Model.Brands" class="form-select" id="BrandDropdown">
                <option value="">-- Wybierz Markę --</option>
            </select>
            <span asp-validation-for="BrandId" class="text-danger"></span>
        </div>

        <div class="col-md-6 mb-3">
            <label asp-for="ModelId" class="form-label"></label>
            @if (Model.BrandId > 0)
            {
                <select asp-for="ModelId" asp-items="Model.Models" class="form-select" id="ModelDropdown">
                    <option value="">-- Wybierz Model --</option>
                </select>
            }
            else
            {
                <select asp-for="ModelId" asp-items="Model.Models" class="form-select" id="ModelDropdown" disabled>
                    <option value="">-- Najpierw wybierz Markę --</option>
                </select>
            }
            <span asp-validation-for="ModelId" class="text-danger"></span>
        </div>
    </div>

    <div class="row">
        <div class="col-md-4 mb-3">
            <label asp-for="FuelTypeId" class="form-label"></label>
            <select asp-for="FuelTypeId" asp-items="Model.FuelTypes" class="form-select">
                <option value="">-- Wybierz --</option>
            </select>
            <span asp-validation-for="FuelTypeId" class="text-danger"></span>
        </div>

        <div class="col-md-4 mb-3">
            <label asp-for="GearboxTypeId" class="form-label"></label>
            <select asp-for="GearboxTypeId" asp-items="Model.GearboxTypes" class="form-select">
                <option value="">-- Wybierz --</option>
            </select>
            <span asp-validation-for="GearboxTypeId" class="text-danger"></span>
        </div>

        <div class="col-md-4 mb-3">
            <label asp-for="DriveTypeId" class="form-label"></label>
            <select asp-for="DriveTypeId" asp-items="Model.DriveTypes" class="form-select">
                <option value="">-- Wybierz --</option>
            </select>
            <span asp-validation-for="DriveTypeId" class="text-danger"></span>
        </div>
    </div>

    <div class="row">
        <div class="col-md-6 mb-3">
            <label asp-for="BodyTypeId" class="form-label"></label>
            <select asp-for="BodyTypeId" asp-items="Model.BodyTypes" class="form-select">
                <option value="">-- Wybierz --</option>
            </select>
            <span asp-validation-for="BodyTypeId" class="text-danger"></span>
        </div>

        <div class="col-md-6 mb-3">
            <label asp-for="VehicleCategoryId" class="form-label"></label>
            <select asp-for="VehicleCategoryId" asp-items="Model.VehicleCategories" class="form-select">
                <option value="">-- Wybierz --</option>
            </select>
            <span asp-validation-for="VehicleCategoryId" class="text-danger"></span>
        </div>
    </div>

    <div class="mb-3">
        <label asp-for="Title" class="form-label">Tytuł ogłoszenia</label>
        <input asp-for="Title" class="form-control" />
        <span asp-validation-for="Title" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Description" class="form-label">Opis</label>
        <textarea asp-for="Description" class="form-control" rows="5"></textarea>
        <span asp-validation-for="Description" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Photos" class="form-label"></label>
        <input asp-for="Photos" class="form-control" type="file" multiple accept="image/*" id="PhotoInput" />
        <span class="form-text">Zdjęcia będą przycinane do 1200x800 (cover).</span>
        <span asp-validation-for="Photos" class="text-danger"></span>
    </div>

    <div id="PhotoPreviewContainer" class="d-flex flex-wrap gap-2 mt-2"></div>

    <div class="mb-3">
        <label asp-for="Price" class="form-label">Cena</label>
        <input asp-for="Price" class="form-control" type="number" step="0.01" min="0" />
        <span asp-validation-for="Price" class="text-danger"></span>
    </div>

    <div class="row">
        <div class="col-md-6 mb-3">
            <label asp-for="VIN" class="form-label">VIN</label>
            <input asp-for="VIN" class="form-control" />
            <span asp-validation-for="VIN" class="text-danger"></span>
        </div>

        <div class="col-md-3 mb-3">
            <label asp-for="ProductionYear" class="form-label">Rok produkcji</label>
            <input asp-for="ProductionYear" class="form-control" type="number" min="1900" max="@DateTime.Now.Year" />
            <span asp-validation-for="ProductionYear" class="text-danger"></span>
        </div>

        <div class="col-md-3 mb-3">
            <label asp-for="Mileage" class="form-label">Przebieg (km)</label>
            <input asp-for="Mileage" class="form-control" type="number" min="0" />
            <span asp-validation-for="Mileage" class="text-danger"></span>
        </div>
    </div>

    <div class="row">
        <div class="col-md-6 mb-3">
            <label asp-for="LocationCity" class="form-label">Miasto</label>
            <input asp-for="LocationCity" class="form-control" />
            <span asp-validation-for="LocationCity" class="text-danger"></span>
        </div>

        <div class="col-md-6 mb-3">
            <label asp-for="LocationRegion" class="form-label">Województwo</label>
            <input asp-for="LocationRegion" class="form-control" />
            <span asp-validation-for="LocationRegion" class="text-danger"></span>
        </div>
    </div>

    <button type="submit" class="btn btn-success btn-lg mt-3">Dodaj ogłoszenie</button>
</form>

@section Scripts {
    <script>
        // Funkcja do ładowania modeli dla wybranej marki
        function loadModels(brandId, selectedModelId) {
            var modelDropdown = $('#ModelDropdown');

            if (!brandId) {
                modelDropdown.empty();
                modelDropdown.append('<option value="">-- Najpierw wybierz Markę --</option>');
                modelDropdown.prop('disabled', true);
                return;
            }

            // Reset
            modelDropdown.empty();
            modelDropdown.append('<option value="">-- Ładowanie... --</option>');
            modelDropdown.prop('disabled', true);

            // Strzał AJAX do API
            $.getJSON('/Listings/GetModelsJson?brandId=' + brandId, function (data) {
                modelDropdown.empty();
                modelDropdown.append('<option value="">-- Wybierz Model --</option>');

                $.each(data, function (index, item) {
                    var option = $('<option>', {
                        value: item.id,
                        text: item.name
                    });
                    
                    // Jeśli mamy selectedModelId, zaznacz odpowiedni model
                    // Porównujemy jako stringi, bo wartości z select są zawsze stringami
                    if (selectedModelId && String(item.id) === String(selectedModelId)) {
                        option.prop('selected', true);
                    }
                    
                    modelDropdown.append(option);
                });
                
                modelDropdown.prop('disabled', false);
            }).fail(function() {
                modelDropdown.empty();
                modelDropdown.append('<option value="">-- Błąd ładowania --</option>');
            });
        }

        // Skrypt do kaskadowych dropdownów
        $(document).ready(function () {
            var brandDropdown = $('#BrandDropdown');
            var modelDropdown = $('#ModelDropdown');
            var initialBrandId = brandDropdown.val();
            var initialModelId = modelDropdown.val();

            // Jeśli na początku mamy już wybraną markę (np. po błędzie walidacji),
            // załaduj modele automatycznie
            if (initialBrandId && initialBrandId > 0) {
                loadModels(initialBrandId, initialModelId);
            }

            // Obsługa zmiany marki
            brandDropdown.change(function () {
                var brandId = $(this).val();
                loadModels(brandId, null);
            });
        });
        // SKRYPT: przycinanie, podgląd i usuwanie zdjęć przed wysłaniem
        $(document).ready(function () {
            const targetWidth = 1200;
            const targetHeight = 800;
            let processedFiles = [];

            const photoInput = document.getElementById('PhotoInput');
            const previewContainer = $('#PhotoPreviewContainer');
            const form = photoInput.closest('form');

            photoInput.addEventListener('change', async function () {
                processedFiles = [];
                previewContainer.empty();

                const files = Array.from(photoInput.files || []);
                for (const file of files) {
                    const resized = await resizeImage(file, targetWidth, targetHeight);
                    processedFiles.push(resized);
                }

                renderPreviews();
                syncInputFiles();
            });

            form.addEventListener('submit', function () {
                // Upewnij się, że input ma zaktualizowaną listę (po ewentualnych usunięciach)
                syncInputFiles();
            });

            function renderPreviews() {
                previewContainer.empty();
                processedFiles.forEach((file, index) => {
                    const reader = new FileReader();
                    reader.onload = function (e) {
                        const wrapper = $('<div class="position-relative">').css({
                            width: '150px',
                            height: '100px'
                        });

                        const img = $('<img>').attr('src', e.target.result)
                            .addClass('img-thumbnail')
                            .css({
                                width: '150px',
                                height: '100px',
                                objectFit: 'cover'
                            });

                        const removeBtn = $('<button type="button" class="btn-close position-absolute top-0 end-0" aria-label="Remove"></button>');
                        removeBtn.on('click', function () {
                            processedFiles.splice(index, 1);
                            renderPreviews();
                            syncInputFiles();
                        });

                        wrapper.append(img).append(removeBtn);
                        previewContainer.append(wrapper);
                    };
                    reader.readAsDataURL(file);
                });
            }

            function syncInputFiles() {
                const dt = new DataTransfer();
                processedFiles.forEach(f => dt.items.add(f));
                photoInput.files = dt.files;
            }

            function resizeImage(file, width, height) {
                return new Promise((resolve, reject) => {
                    const reader = new FileReader();
                    reader.onload = function (e) {
                        const img = new Image();
                        img.onload = function () {
                            const canvas = document.createElement('canvas');
                            canvas.width = width;
                            canvas.height = height;
                            const ctx = canvas.getContext('2d');

                            // cover: skalujemy tak, by wypełnić docelowy obszar i przycinamy
                            const scale = Math.max(width / img.width, height / img.height);
                            const sw = width / scale;
                            const sh = height / scale;
                            const sx = (img.width - sw) / 2;
                            const sy = (img.height - sh) / 2;

                            ctx.drawImage(img, sx, sy, sw, sh, 0, 0, width, height);
                            canvas.toBlob(blob => {
                                if (!blob) return reject(new Error('Blob null'));
                                // Zastępujemy plik nowym, przyciętym
                                const resizedFile = new File([blob], file.name, { type: file.type, lastModified: Date.now() });
                                resolve(resizedFile);
                            }, file.type || 'image/jpeg', 0.9);
                        };
                        img.onerror = reject;
                        img.src = e.target.result;
                    };
                    reader.onerror = reject;
                    reader.readAsDataURL(file);
                });
            }
        });
    </script>
}