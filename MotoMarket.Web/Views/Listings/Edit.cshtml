@model MotoMarket.Web.Models.ViewModels.CreateListingViewModel

@{
    ViewData["Title"] = "Edytuj ogłoszenie";
}

<div class="container mt-4 mb-5">
    <div class="row">
        <div class="col-lg-10 mx-auto">
            <div class="card shadow-lg border-0">
                <div class="card-header bg-warning text-dark py-4">
                    <h2 class="mb-0 fw-bold">
                        <i class="bi bi-pencil-square me-2"></i>Edytuj ogłoszenie
                    </h2>
                    <p class="mb-0 mt-2 opacity-90">Zaktualizuj informacje o swoim ogłoszeniu</p>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Edit" method="post" enctype="multipart/form-data">
                        <input type="hidden" asp-for="Id" />
                        <!-- Basic Information -->
                        <div class="mb-5">
                            <h4 class="fw-bold mb-4 pb-2 border-bottom">
                                <i class="bi bi-info-circle text-primary me-2"></i>Podstawowe informacje
                            </h4>
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label asp-for="BrandId" class="form-label fw-semibold">Marka *</label>
                                    <select asp-for="BrandId" asp-items="Model.Brands" class="form-select" id="BrandDropdown">
                                        <option value="">-- Wybierz Markę --</option>
                                    </select>
                                    <span asp-validation-for="BrandId" class="text-danger small"></span>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label asp-for="ModelId" class="form-label fw-semibold">Model *</label>
                                    @if (Model.BrandId > 0)
                                    {
                                        <select asp-for="ModelId" asp-items="Model.Models" class="form-select" id="ModelDropdown">
                                            <option value="">-- Wybierz Model --</option>
                                        </select>
                                    }
                                    else
                                    {
                                        <select asp-for="ModelId" asp-items="Model.Models" class="form-select" id="ModelDropdown" disabled>
                                            <option value="">-- Najpierw wybierz Markę --</option>
                                        </select>
                                    }
                                    <span asp-validation-for="ModelId" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>

                        <!-- Vehicle Specifications -->
                        <div class="mb-5">
                            <h4 class="fw-bold mb-4 pb-2 border-bottom">
                                <i class="bi bi-gear-wide-connected text-primary me-2"></i>Specyfikacja pojazdu
                            </h4>
                            <div class="row">
                                <div class="col-md-4 mb-3">
                                    <label asp-for="FuelTypeId" class="form-label fw-semibold">Typ paliwa *</label>
                                    <select asp-for="FuelTypeId" asp-items="Model.FuelTypes" class="form-select">
                                        <option value="">-- Wybierz --</option>
                                    </select>
                                    <span asp-validation-for="FuelTypeId" class="text-danger small"></span>
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label asp-for="GearboxTypeId" class="form-label fw-semibold">Skrzynia biegów *</label>
                                    <select asp-for="GearboxTypeId" asp-items="Model.GearboxTypes" class="form-select">
                                        <option value="">-- Wybierz --</option>
                                    </select>
                                    <span asp-validation-for="GearboxTypeId" class="text-danger small"></span>
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label asp-for="DriveTypeId" class="form-label fw-semibold">Napęd *</label>
                                    <select asp-for="DriveTypeId" asp-items="Model.DriveTypes" class="form-select">
                                        <option value="">-- Wybierz --</option>
                                    </select>
                                    <span asp-validation-for="DriveTypeId" class="text-danger small"></span>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label asp-for="BodyTypeId" class="form-label fw-semibold">Typ nadwozia *</label>
                                    <select asp-for="BodyTypeId" asp-items="Model.BodyTypes" class="form-select">
                                        <option value="">-- Wybierz --</option>
                                    </select>
                                    <span asp-validation-for="BodyTypeId" class="text-danger small"></span>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label asp-for="VehicleCategoryId" class="form-label fw-semibold">Kategoria *</label>
                                    <select asp-for="VehicleCategoryId" asp-items="Model.VehicleCategories" class="form-select">
                                        <option value="">-- Wybierz --</option>
                                    </select>
                                    <span asp-validation-for="VehicleCategoryId" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>

                        <!-- Title and Description -->
                        <div class="mb-5">
                            <h4 class="fw-bold mb-4 pb-2 border-bottom">
                                <i class="bi bi-file-text text-primary me-2"></i>Opis ogłoszenia
                            </h4>
                            <div class="mb-3">
                                <label asp-for="Title" class="form-label fw-semibold">Tytuł ogłoszenia *</label>
                                <input asp-for="Title" class="form-control" />
                                <span asp-validation-for="Title" class="text-danger small"></span>
                            </div>
                            <div class="mb-3">
                                <label asp-for="Description" class="form-label fw-semibold">Opis *</label>
                                <textarea asp-for="Description" class="form-control" rows="6"></textarea>
                                <span asp-validation-for="Description" class="text-danger small"></span>
                            </div>
                        </div>

                        <!-- Technical Parameters -->
                        <div class="mb-5">
                            <h4 class="fw-bold mb-4 pb-2 border-bottom">
                                <i class="bi bi-sliders text-primary me-2"></i>Parametry pojazdu
                            </h4>

    <div class="row g-3">
        @foreach (var param in Model.AvailableParameters)
        {
            <div class="col-md-4">
                <label class="form-label">@param.Name</label>
                <div class="input-group">
                    <input type="text"
                           class="form-control"
                           name="Parameters[@param.Id]"
                           value="@(Model.Parameters != null && Model.Parameters.ContainsKey(param.Id) ? Model.Parameters[param.Id] : "")"
                           placeholder="@param.Name" />

                    @if (!string.IsNullOrEmpty(param.Unit))
                    {
                        <span class="input-group-text">@param.Unit</span>
                    }
                </div>
            </div>
        }
    </div>

                        <!-- Features -->
                        <div class="mb-5">
                            <h4 class="fw-bold mb-4 pb-2 border-bottom">
                                <i class="bi bi-star-fill text-primary me-2"></i>Wyposażenie pojazdu
                            </h4>
                            <div class="row">
                                @foreach (var group in Model.AvailableFeatures.GroupBy(x => x.GroupName))
                                {
                                    <div class="col-12 mb-3">
                                        <h6 class="text-primary fw-semibold mb-3 pb-2 border-bottom">@group.Key</h6>
                                    </div>
                                    @foreach (var feature in group)
                                    {
                                        <div class="col-md-3 col-sm-6 mb-2">
                                            <div class="form-check p-2 border rounded">
                                                <input class="form-check-input"
                                                       type="checkbox"
                                                       name="SelectedFeatureIds"
                                                       value="@feature.Id"
                                                       id="feat_@feature.Id"
                                                       @(Model.SelectedFeatureIds.Contains(feature.Id) ? "checked" : "")>
                                                <label class="form-check-label" for="feat_@feature.Id">
                                                    @feature.Name
                                                </label>
                                            </div>
                                        </div>
                                    }
                                }
                            </div>
                        </div>

                        <!-- Price and Basic Details -->
                        <div class="mb-5">
                            <h4 class="fw-bold mb-4 pb-2 border-bottom">
                                <i class="bi bi-currency-dollar text-primary me-2"></i>Cena i podstawowe dane
                            </h4>
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label asp-for="Price" class="form-label fw-semibold">Cena (PLN) *</label>
                                    <input asp-for="Price" class="form-control" type="number" step="0.01" min="0" />
                                    <span asp-validation-for="Price" class="text-danger small"></span>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label asp-for="VIN" class="form-label fw-semibold">VIN</label>
                                    <input asp-for="VIN" class="form-control" />
                                    <span asp-validation-for="VIN" class="text-danger small"></span>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label asp-for="ProductionYear" class="form-label fw-semibold">Rok produkcji *</label>
                                    <input asp-for="ProductionYear" class="form-control" type="number" min="1900" max="@DateTime.Now.Year" />
                                    <span asp-validation-for="ProductionYear" class="text-danger small"></span>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label asp-for="Mileage" class="form-label fw-semibold">Przebieg (km) *</label>
                                    <input asp-for="Mileage" class="form-control" type="number" min="0" />
                                    <span asp-validation-for="Mileage" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>

                        <!-- Location -->
                        <div class="mb-5">
                            <h4 class="fw-bold mb-4 pb-2 border-bottom">
                                <i class="bi bi-geo-alt text-primary me-2"></i>Lokalizacja
                            </h4>
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label asp-for="LocationCity" class="form-label fw-semibold">Miasto *</label>
                                    <input asp-for="LocationCity" class="form-control" />
                                    <span asp-validation-for="LocationCity" class="text-danger small"></span>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label asp-for="LocationRegion" class="form-label fw-semibold">Województwo *</label>
                                    <input asp-for="LocationRegion" class="form-control" />
                                    <span asp-validation-for="LocationRegion" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>

                        <!-- Photos -->
                        <div class="mb-5">
                            <h4 class="fw-bold mb-4 pb-2 border-bottom">
                                <i class="bi bi-images text-primary me-2"></i>Zdjęcia
                            </h4>
                            <div class="mb-3">
                                <label asp-for="Photos" class="form-label fw-semibold">Zdjęcia (opcjonalnie podmień)</label>
                                <input asp-for="Photos" class="form-control" type="file" multiple accept="image/*" id="PhotoInput" />
                                <span class="form-text">Jeśli dodasz nowe zdjęcia, stare zostaną zastąpione. Możesz ustawić kolejność i zdjęcie główne.</span>
                                <span asp-validation-for="Photos" class="text-danger small"></span>
                            </div>
                            <div id="PhotoPreviewContainer" class="d-flex flex-wrap gap-3 mt-3"></div>
                            <div id="PhotoMetaContainer"></div>
                        </div>

                        <!-- Submit Button -->
                        <div class="d-flex justify-content-between align-items-center pt-4 border-top">
                            <a asp-action="MyListings" class="btn btn-outline-secondary">
                                <i class="bi bi-arrow-left me-1"></i>Anuluj
                            </a>
                            <button type="submit" class="btn btn-success btn-lg px-5">
                                <i class="bi bi-check-lg me-2"></i>Zapisz zmiany
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Funkcja do ładowania modeli dla wybranej marki
        function loadModels(brandId, selectedModelId) {
            var modelDropdown = $('#ModelDropdown');

            if (!brandId) {
                modelDropdown.empty();
                modelDropdown.append('<option value="">-- Najpierw wybierz Markę --</option>');
                modelDropdown.prop('disabled', true);
                return;
            }

            // Reset
            modelDropdown.empty();
            modelDropdown.append('<option value="">-- Ładowanie... --</option>');
            modelDropdown.prop('disabled', true);

            // Strzał AJAX do API
            $.getJSON('/Listings/GetModelsJson?brandId=' + brandId, function (data) {
                modelDropdown.empty();
                modelDropdown.append('<option value="">-- Wybierz Model --</option>');

                $.each(data, function (index, item) {
                    var option = $('<option>', {
                        value: item.id,
                        text: item.name
                    });
                    
                    // Jeśli mamy selectedModelId, zaznacz odpowiedni model
                    // Porównujemy jako stringi, bo wartości z select są zawsze stringami
                    if (selectedModelId && String(item.id) === String(selectedModelId)) {
                        option.prop('selected', true);
                    }
                    
                    modelDropdown.append(option);
                });
                
                modelDropdown.prop('disabled', false);
            }).fail(function() {
                modelDropdown.empty();
                modelDropdown.append('<option value="">-- Błąd ładowania --</option>');
            });
        }

        // Skrypt do kaskadowych dropdownów
        $(document).ready(function () {
            var brandDropdown = $('#BrandDropdown');
            var modelDropdown = $('#ModelDropdown');
            var initialBrandId = brandDropdown.val();
            var initialModelId = modelDropdown.val();

            // Jeśli na początku mamy już wybraną markę (np. po błędzie walidacji lub w Edit),
            // załaduj modele automatycznie
            if (initialBrandId && initialBrandId > 0) {
                loadModels(initialBrandId, initialModelId);
            }

            // Obsługa zmiany marki
            brandDropdown.change(function () {
                var brandId = $(this).val();
                loadModels(brandId, null);
            });
        });
    </script>

    <script>
        // SKRYPT: przycinanie, podgląd, usuwanie, kolejność i zdjęcie główne przed wysłaniem (Edit)
        $(document).ready(function () {
            const targetWidth = 1200;
            const targetHeight = 800;
            let processedFiles = [];
            let mainIndex = 0;

            const photoInput = document.getElementById('PhotoInput');
            if (!photoInput) return;

            const previewContainer = $('#PhotoPreviewContainer');
            const metaContainer = $('#PhotoMetaContainer');
            const form = photoInput.closest('form');

            photoInput.addEventListener('change', async function () {
                processedFiles = [];
                mainIndex = 0;
                previewContainer.empty();

                const files = Array.from(photoInput.files || []);
                for (let idx = 0; idx < files.length; idx++) {
                    const file = files[idx];
                    const resized = await resizeImage(file, targetWidth, targetHeight);
                    processedFiles.push({
                        file: resized,
                        sortOrder: idx,
                        isMain: idx === 0
                    });
                }

                renderPreviews();
                syncInputFiles();
            });

            form.addEventListener('submit', function () {
                syncInputFiles();
            });

            function renderPreviews() {
                previewContainer.empty();
                processedFiles.forEach((item, index) => {
                    const reader = new FileReader();
                    reader.onload = function (e) {
                        const wrapper = $('<div class="position-relative border rounded p-1">').css({
                            width: '170px'
                        });

                        const img = $('<img>').attr('src', e.target.result)
                            .addClass('img-thumbnail mb-1')
                            .css({
                                width: '150px',
                                height: '100px',
                                objectFit: 'cover'
                            });

                        const btnGroup = $('<div class="btn-group btn-group-sm w-100 mb-1" role="group"></div>');
                        const upBtn = $('<button type="button" class="btn btn-light" title="Do góry">⬆️</button>').on('click', function () {
                            if (index > 0) {
                                swap(index, index - 1);
                            }
                        });
                        const downBtn = $('<button type="button" class="btn btn-light" title="W dół">⬇️</button>').on('click', function () {
                            if (index < processedFiles.length - 1) {
                                swap(index, index + 1);
                            }
                        });
                        btnGroup.append(upBtn, downBtn);

                        const mainToggle = $('<div class="form-check form-check-inline mb-1"></div>');
                        const mainRadio = $('<input class="form-check-input" type="radio" name="mainPhotoRadio">')
                            .prop('checked', item.isMain)
                            .on('change', function () {
                                setMain(index);
                            });
                        const mainLabel = $('<label class="form-check-label small">Główne</label>');
                        mainToggle.append(mainRadio, mainLabel);

                        const removeBtn = $('<button type="button" class="btn btn-outline-danger btn-sm w-100">Usuń</button>').on('click', function () {
                            processedFiles.splice(index, 1);
                            if (mainIndex === index) {
                                mainIndex = 0;
                            } else if (index < mainIndex) {
                                mainIndex -= 1;
                            }
                            if (processedFiles.length === 0) {
                                mainIndex = 0;
                            } else {
                                setMain(Math.min(mainIndex, processedFiles.length - 1));
                            }
                            renderPreviews();
                            syncInputFiles();
                        });

                        wrapper.append(img, btnGroup, mainToggle, removeBtn);
                        previewContainer.append(wrapper);
                    };
                    reader.readAsDataURL(item.file);
                });
            }

            function syncInputFiles() {
                const dt = new DataTransfer();
                processedFiles.forEach(f => dt.items.add(f.file));
                photoInput.files = dt.files;

                metaContainer.empty();
                metaContainer.append($('<input type="hidden" name="MainPhotoIndex">').val(mainIndex));
                processedFiles.forEach((f, idx) => {
                    metaContainer.append($('<input type="hidden" name="PhotoSortOrders">').val(f.sortOrder));
                });
            }

            function setMain(idx) {
                processedFiles = processedFiles.map((p, i) => ({ ...p, isMain: i === idx }));
                mainIndex = idx;
                renderPreviews();
                syncInputFiles();
            }

            function swap(i, j) {
                const temp = processedFiles[i];
                processedFiles[i] = processedFiles[j];
                processedFiles[j] = temp;
                processedFiles = processedFiles.map((p, idx) => ({ ...p, sortOrder: idx }));
                if (mainIndex === i) mainIndex = j;
                else if (mainIndex === j) mainIndex = i;
                renderPreviews();
                syncInputFiles();
            }

            function resizeImage(file, width, height) {
                return new Promise((resolve, reject) => {
                    const reader = new FileReader();
                    reader.onload = function (e) {
                        const img = new Image();
                        img.onload = function () {
                            const canvas = document.createElement('canvas');
                            canvas.width = width;
                            canvas.height = height;
                            const ctx = canvas.getContext('2d');

                            const scale = Math.max(width / img.width, height / img.height);
                            const sw = width / scale;
                            const sh = height / scale;
                            const sx = (img.width - sw) / 2;
                            const sy = (img.height - sh) / 2;

                            ctx.drawImage(img, sx, sy, sw, sh, 0, 0, width, height);
                            canvas.toBlob(blob => {
                                if (!blob) return reject(new Error('Blob null'));
                                const resizedFile = new File([blob], file.name, { type: file.type, lastModified: Date.now() });
                                resolve(resizedFile);
                            }, file.type || 'image/jpeg', 0.9);
                        };
                        img.onerror = reject;
                        img.src = e.target.result;
                    };
                    reader.onerror = reject;
                    reader.readAsDataURL(file);
                });
            }
        });
    </script>
}