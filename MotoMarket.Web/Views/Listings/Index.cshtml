@using MotoMarket.Web.Models.DTOs
@model MotoMarket.Web.Models.ViewModels.ListingsFilterViewModel

@{
    ViewData["Title"] = "Ogłoszenia";
}

<div class="container-fluid mt-4 mb-5">
    <div class="row">
        <div class="col-md-3">
            <div class="card p-4 shadow-lg sticky-top border-0" style="top: 1rem; z-index: 100; border-radius: var(--radius-xl);">
                <h4 class="mb-4 fw-bold">
                    <i class="bi bi-funnel me-2 text-primary"></i>Filtrowanie
                </h4>

                <form asp-action="Index" method="get" id="filterForm">

                    <div class="mb-3">
                        <input asp-for="Search" class="form-control" placeholder="Szukaj po tytule" />
                    </div>

                    <div class="mb-3">
                        <label asp-for="BrandId" class="form-label">Marka</label>
                        <select asp-for="BrandId" asp-items="Model.Brands" class="form-select" id="BrandFilter">
                            <option value="">Wszystkie marki</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label asp-for="ModelId" class="form-label">Model</label>
                        <select asp-for="ModelId"
                                asp-items="Model.Models"
                                class="form-select"
                                id="ModelFilter"
                                disabled="@(Model.BrandId == null ? "disabled" : null)">
                            <option value="">Wszystkie modele</option>
                        </select>
                    </div>

                    <label class="form-label">Cena (PLN)</label>
                    <div class="row mb-3">
                        <div class="col-6">
                            <input asp-for="PriceMin" class="form-control" placeholder="Od" type="number" />
                        </div>
                        <div class="col-6">
                            <input asp-for="PriceMax" class="form-control" placeholder="Do" type="number" />
                        </div>
                    </div>

                    <label class="form-label">Rok produkcji</label>
                    <div class="row mb-3">
                        <div class="col-6">
                            <input asp-for="YearMin" class="form-control" placeholder="Od" type="number" />
                        </div>
                        <div class="col-6">
                            <input asp-for="YearMax" class="form-control" placeholder="Do" type="number" />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="SortBy" class="form-label">Sortuj</label>
                        <select asp-for="SortBy" class="form-select">
                            <option value="newest">Najnowsze</option>
                            <option value="price_asc">Cena: rosnąco</option>
                            <option value="price_desc">Cena: malejąco</option>
                            <option value="oldest">Najstarsze</option>
                        </select>
                    </div>

                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-search me-1"></i>Filtruj
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">
                            <i class="bi bi-x-circle me-1"></i>Wyczyść filtry
                        </a>
                    </div>
                </form>
            </div>
        </div>

        <div class="col-md-9">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h1 class="display-5 fw-bold mb-2">
                        <i class="bi bi-car-front text-primary me-2"></i>Ogłoszenia
                    </h1>
                    <p class="text-muted mb-0">
                        <i class="bi bi-check-circle me-1"></i>Znaleziono: <strong>@Model.Listings.Count()</strong> ofert
                    </p>
                </div>
                <a asp-action="Create" class="btn btn-success btn-lg shadow">
                    <i class="bi bi-plus-circle me-1"></i>Sprzedaj auto
                </a>
            </div>

            <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
                @foreach (var item in Model.Listings)
                {
                    <div class="col">
                        <div class="card h-100 shadow-sm border-0 overflow-hidden">
                            <div class="position-relative">
                                <button type="button"
                                        class="btn btn-light position-absolute top-0 end-0 m-2 rounded-circle shadow-sm favorite-btn d-flex align-items-center justify-content-center"
                                        style="width: 40px; height: 40px; z-index: 2; backdrop-filter: blur(10px);"
                                        data-id="@item.Id"
                                        title="@(item.IsFavorite ? "Usuń z ulubionych" : "Dodaj do ulubionych")">
                                    @if (item.IsFavorite)
                                    {
                                        <i class="bi bi-heart-fill text-danger fs-5"></i>
                                    }
                                    else
                                    {
                                        <i class="bi bi-heart text-danger fs-5"></i>
                                    }
                                </button>
                                @if (!string.IsNullOrEmpty(item.MainPhotoUrl))
                                {
                                    <img src="@item.MainPhotoUrl" class="card-img-top" alt="@item.Title" style="height: 220px; object-fit: cover;">
                                }
                                else
                                {
                                    <div class="card-img-top d-flex align-items-center justify-content-center bg-secondary text-white" style="height: 220px;">
                                        <i class="bi bi-image fs-1"></i>
                                    </div>
                                }
                                <span class="badge bg-primary position-absolute bottom-0 end-0 m-2 px-3 py-2 fs-6 fw-bold">
                                    @item.Price.ToString("N0") PLN
                                </span>
                            </div>

                            <div class="card-body">
                                <h5 class="card-title fw-bold mb-2">@item.BrandName @item.ModelName</h5>
                                <h6 class="card-subtitle mb-3 text-muted small">@item.Title</h6>
                                
                                <div class="d-flex flex-wrap gap-2 mb-3">
                                    <small class="text-muted">
                                        <i class="bi bi-calendar3 me-1"></i>@item.ProductionYear
                                    </small>
                                    <small class="text-muted">
                                        <i class="bi bi-speedometer2 me-1"></i>@(item.Mileage / 1000) tys. km
                                    </small>
                                    <small class="text-muted">
                                        <i class="bi bi-geo-alt me-1"></i>@item.LocationCity
                                    </small>
                                </div>
                            </div>

                            <div class="card-footer bg-white border-0 pt-0 pb-3">
                                <a asp-controller="Listings" asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-primary w-100">
                                    Zobacz szczegóły <i class="bi bi-arrow-right ms-1"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                }
            </div>

            @if (!Model.Listings.Any())
            {
                <div class="card shadow-lg border-0 text-center mt-5">
                    <div class="card-body p-5">
                        <i class="bi bi-search text-muted" style="font-size: 4rem;"></i>
                        <h4 class="mt-4 mb-3">Nie znaleziono ogłoszeń</h4>
                        <p class="text-muted mb-4">Spróbuj zmienić filtry lub wyczyść wyszukiwanie.</p>
                        <a asp-action="Index" class="btn btn-primary">
                            <i class="bi bi-arrow-clockwise me-1"></i>Wyczyść filtry
                        </a>
                    </div>
                </div>
            }

        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            // Logika ładowania modeli po zmianie marki
            $('#BrandFilter').change(function () {
                var brandId = $(this).val();
                var modelDropdown = $('#ModelFilter');

                modelDropdown.empty();
                modelDropdown.append('<option value="">Wszystkie modele</option>');
                modelDropdown.prop('disabled', true); // Blokujemy na czas ładowania

                if (brandId) {
                    $.getJSON('/Listings/GetModelsJson?brandId=' + brandId, function (data) {
                        $.each(data, function (index, item) {
                            modelDropdown.append($('<option>', {
                                value: item.id,
                                text: item.name
                            }));
                        });
                        modelDropdown.prop('disabled', false); // Odblokowujemy jak są dane
                    });
                }
            });
        });
                $(document).ready(function() {
            // Obsługa kliknięcia w serce
            $('.favorite-btn').click(function(e) {
                e.preventDefault(); // Żeby nie klikało w link pod spodem (jeśli jest)
                var btn = $(this);
                var icon = btn.find('i');
                var id = btn.data('id');

                // Strzał do kontrolera MVC (który strzela do API)
                $.post('/Listings/ToggleFavoriteJson/' + id, function(data) {
                    if (data.success) {
                        if (data.isFavorite) {
                            // Zmieniamy na pełne serce
                            icon.removeClass('bi-heart').addClass('bi-heart-fill');
                            // Opcjonalnie: animacja
                        } else {
                            // Zmieniamy na puste serce
                            icon.removeClass('bi-heart-fill').addClass('bi-heart');
                        }
                    } else {
                        alert('Musisz być zalogowany!');
                        window.location.href = '/Auth/Login';
                    }
                });
            });
        });
    </script>
}