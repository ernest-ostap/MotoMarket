@using MotoMarket.Web.Models.DTOs
@model IEnumerable<ListingDto>

@{
    ViewData["Title"] = "Strona Główna";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="display-4">Wszystkie ogłoszenia</h1>

    <a asp-action="Create" class="btn btn-success btn-lg">
        Sprzedaj swój samochód
    </a>
</div>

<div class="row">
    @foreach (var item in Model)
    {
        <div class="col-md-4 mb-4">
            <div class="card h-100 shadow-sm">
                @if (!string.IsNullOrEmpty(item.MainPhotoUrl))
                {
                    <img src="@item.MainPhotoUrl" class="card-img-top" alt="@item.Title" style="height: 200px; object-fit: cover;">
                }
                else
                {
                    <img src="https://via.placeholder.com/300x200?text=Brak+Zdjecia" class="card-img-top" alt="No image">
                }

                <div class="card-body">
                    <h5 class="card-title">@item.BrandName @item.ModelName</h5>
                    <h6 class="card-subtitle mb-2 text-muted">@item.Title</h6>
                    <p class="card-text text-truncate">@item.Description</p>

                    <div class="d-flex justify-content-between align-items-center">
                        <span class="h5 text-primary mb-0">@item.Price.ToString("C0")</span>
                        <small class="text-muted">@item.LocationCity</small>
                    </div>
                </div>
                <div class="card-footer bg-white border-top-0">
                    <a asp-controller="Listings" asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-primary w-100">
                        Zobacz szczegóły
                    </a>
                </div>
            </div>
        </div>
    }
</div>