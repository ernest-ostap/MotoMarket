@model IEnumerable<MotoMarket.Web.Models.DTOs.UserDto>
@{
    ViewData["Title"] = "Użytkownicy";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2><i class="bi bi-people-fill"></i> Użytkownicy Systemu</h2>
    </div>

    <div class="table-responsive shadow-sm">
        <table class="table table-hover bg-white align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>Email</th>
                    <th>Imię i Nazwisko</th>
                    <th>Rola</th>
                    <th>Status</th>
                    <th>Akcje</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model)
                {
                    // Podświetlamy wiersz, jeśli zbanowany
                    <tr class="@(user.IsBanned ? "table-danger" : "")">
                        <td class="fw-bold">@user.Email</td>
                        <td>@user.FirstName @user.LastName</td>
                        <td>
                            @if (user.Role == "Admin")
                            {
                                <span class="badge bg-primary">Admin</span>
                            }
                            else
                            {

                                <span class="badge bg-secondary">User</span>
                            }
                        </td>
                        <td>
                            @if (user.IsBanned)
                            {
                                <span class="text-danger fw-bold"><i class="bi bi-slash-circle"></i> ZBANOWANY</span>
                            }
                            else
                            {
                                <span class="text-success"><i class="bi bi-check-circle"></i> Aktywny</span>
                            }
                        </td>
                        <td>
                            @if (User.Identity.Name != user.Email)
                            {
                                <form asp-action="ToggleBan" asp-route-id="@user.Id" method="post" onsubmit="return confirm('Czy na pewno chcesz zmienić status blokady tego użytkownika?');">
                                    @if (user.IsBanned)
                                    {
                                        <button type="submit" class="btn btn-sm btn-success">
                                            <i class="bi bi-unlock-fill"></i> Odblokuj
                                        </button>
                                    }
                                    else
                                    {
                                        <button type="submit" class="btn btn-sm btn-danger">
                                            <i class="bi bi-hammer"></i> Zbanuj
                                        </button>
                                    }
                                </form>
                                <form asp-action="ToggleAdmin" asp-route-id="@user.Id" method="post" style="display:inline;" onsubmit="return confirm('Czy na pewno chcesz zmienić uprawnienia tego użytkownika?');">
                                    @if (user.Role == "Admin")
                                    {
                                        <button type="submit" class="btn btn-sm btn-outline-primary" title="Zabierz uprawnienia Admina">
                                            <i class="bi bi-person-down"></i> Degraduj
                                        </button>
                                    }
                                    else
                                    {
                                        <button type="submit" class="btn btn-sm btn-primary" title="Nadaj uprawnienia Admina">
                                            <i class="bi bi-person-up"></i> Awansuj
                                        </button>
                                    }
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <a asp-controller="Admin" asp-action="Index" class="btn btn-secondary mt-3">Wróć do Panelu</a>
</div>