@{
    ViewData["Title"] = "Panel Administratora";
    Layout = "_Layout";
}

<div class="container mt-4 mb-5">
    <div class="card shadow-lg border-0 mb-5" style="background: linear-gradient(135deg, #dc2626 0%, #b91c1c 100%);">
        <div class="card-body text-white p-5">
            <h1 class="display-4 fw-bold mb-3">
                <i class="bi bi-shield-lock-fill me-2"></i>Panel Administratora
            </h1>
            <p class="fs-5 mb-0 opacity-90">Centrum zarządzania systemem MotoMarket</p>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-md-4">
            <div class="card h-100 shadow-lg border-0">
                <div class="card-header bg-primary text-white py-3">
                    <h5 class="mb-0 fw-bold">
                        <i class="bi bi-car-front-fill me-2"></i>Pojazdy
                    </h5>
                </div>
                <div class="list-group list-group-flush">
                    <a asp-controller="Brands" asp-action="Index" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center border-0">
                        <span><i class="bi bi-tag me-2 text-primary"></i>Marki</span>
                        <i class="bi bi-arrow-right text-muted"></i>
                    </a>
                    <a asp-controller="Models" asp-action="Index" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center border-0">
                        <span><i class="bi bi-tags me-2 text-primary"></i>Modele</span>
                        <i class="bi bi-arrow-right text-muted"></i>
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100 shadow-lg border-0">
                <div class="card-header bg-info text-white py-3">
                    <h5 class="mb-0 fw-bold">
                        <i class="bi bi-gear-wide-connected me-2"></i>Parametry
                    </h5>
                </div>
                <div class="list-group list-group-flush">
                    <a asp-controller="FuelTypes" asp-action="Index" class="list-group-item list-group-item-action border-0">
                        <i class="bi bi-fuel-pump me-2 text-info"></i>Typy Paliwa
                    </a>
                    <a asp-controller="GearboxTypes" asp-action="Index" class="list-group-item list-group-item-action border-0">
                        <i class="bi bi-gear me-2 text-info"></i>Skrzynie Biegów
                    </a>
                    <a asp-controller="DriveTypes" asp-action="Index" class="list-group-item list-group-item-action border-0">
                        <i class="bi bi-diagram-3 me-2 text-info"></i>Napędy
                    </a>
                    <a asp-controller="BodyTypes" asp-action="Index" class="list-group-item list-group-item-action border-0">
                        <i class="bi bi-car-front me-2 text-info"></i>Typy Nadwozia
                    </a>
                    <a asp-controller="VehicleCategories" asp-action="Index" class="list-group-item list-group-item-action border-0">
                        <i class="bi bi-grid me-2 text-info"></i>Kategorie
                    </a>
                    <a asp-controller="ParameterTypes" asp-action="Index" class="list-group-item list-group-item-action border-0 fw-semibold">
                        <i class="bi bi-sliders me-2 text-primary"></i>Parametry Techniczne
                    </a>
                    <a asp-controller="Features" asp-action="Index" class="list-group-item list-group-item-action border-0 fw-semibold">
                        <i class="bi bi-star-fill me-2 text-warning"></i>Wyposażenie
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100 shadow-lg border-0">
                <div class="card-header bg-warning text-dark py-3">
                    <h5 class="mb-0 fw-bold">
                        <i class="bi bi-shield-lock-fill me-2"></i>Administracja
                    </h5>
                </div>
                <div class="card-body">
                    <p class="card-text text-muted mb-4">Narzędzia do zarządzania treścią i użytkownikami.</p>
                    <div class="d-grid gap-2">
                        <a asp-controller="Users" asp-action="Index" class="btn btn-outline-dark">
                            <i class="bi bi-people-fill me-2"></i>Użytkownicy
                        </a>
                        <a asp-controller="AdminListings" asp-action="Index" class="btn btn-outline-dark">
                            <i class="bi bi-list-ul me-2"></i>Ogłoszenia
                        </a>
                        <a asp-controller="PageContent" asp-action="Index" class="btn btn-outline-dark">
                            <i class="bi bi-file-text me-2"></i>Zawartość strony
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>