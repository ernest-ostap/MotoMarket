@{
    ViewData["Title"] = "Panel Administratora";
    Layout = "_Layout"; // Na razie zwykły, potem zrobimy osobny
}

<div class="container mt-5">
    <div class="p-5 mb-4 bg-light rounded-3 shadow">
        <div class="container-fluid py-5">
            <h1 class="display-5 fw-bold text-danger">Panel Administratora 🛠️</h1>
            <p class="col-md-8 fs-4">Witaj w centrum dowodzenia.</p>

            <hr class="my-4" />

            <div class="row">
                <div class="col-md-4">
                    <div class="card text-white bg-primary mb-3">
                        <div class="card-header">Słowniki</div>
                        <div class="card-body">
                            <h5 class="card-title">Marki i Modele</h5>
                            <p class="card-text">Zarządzaj bazą dostępnych pojazdów.</p>
                            <a href="#" class="btn btn-light">Zarządzaj</a>
                        </div>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="card text-white bg-warning mb-3">
                        <div class="card-header">Ogłoszenia</div>
                        <div class="card-body">
                            <h5 class="card-title">Moderacja</h5>
                            <p class="card-text">Przeglądaj, usuwaj i banuj ogłoszenia.</p>
                            <a href="#" class="btn btn-light">Moderuj</a>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>