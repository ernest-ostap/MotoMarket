@using MotoMarket.Web.Models.DTOs
@model IEnumerable<ConversationDto>

@{
    ViewData["Title"] = "Moje wiadomości";
}

<div class="container mt-4">
    <h2>Skrzynka odbiorcza 📬</h2>
    <hr />

    @if (!Model.Any())
    {
        <div class="alert alert-info">Nie masz jeszcze żadnych wiadomości.</div>
    }
    else
    {
        <div class="list-group">
            @foreach (var chat in Model)
            {
                <a asp-action="Conversation"
                   asp-route-recipientId="@chat.OtherUserId"
                   asp-route-listingId="@chat.ListingId"
                   class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">

                    <div>
                        <h5 class="mb-1">Rozmówca <small class="text-muted" style="font-size: 0.6em">(@chat.OtherUserId)</small></h5>
                        <p class="mb-1 text-muted text-truncate" style="max-width: 500px;">
                            @chat.LastMessage
                        </p>
                    </div>

                    <small class="text-muted">
                        @chat.LastMessageDate.ToLocalTime().ToString("g")
                    </small>
                </a>
            }
        </div>
    }
</div>