<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:model="clr-namespace:MotoMarket.Mobile.Models.Listings"
             xmlns:vm="clr-namespace:MotoMarket.Mobile.ViewModels"
             x:Class="MotoMarket.Mobile.Views.MyListingsPage"
             Title="Moje ogłoszenia"
             BackgroundColor="{StaticResource BackgroundSecondary}">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="+ Dodaj" Command="{Binding GoToCreateCommand}" />
    </ContentPage.ToolbarItems>

    <Grid RowDefinitions="Auto, *">
        <!-- Loading Indicator -->
        <ActivityIndicator Grid.Row="0"
                           IsRunning="{Binding IsBusy}" 
                           IsVisible="{Binding IsBusy}" 
                           HeightRequest="40"
                           Margin="0,20,0,0"/>

        <!-- Listings -->
        <CollectionView Grid.Row="1" 
                        ItemsSource="{Binding Listings}" 
                        Margin="12">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" 
                                   ItemSpacing="12"/>
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="model:ListingDto">
                    <SwipeView>
                        <SwipeView.RightItems>
                            <SwipeItems>
                                <SwipeItem Text="Zarządzaj"
                                           BackgroundColor="{StaticResource Secondary}"
                                           Command="{Binding Source={RelativeSource AncestorType={x:Type vm:MyListingsViewModel}}, Path=ChangeStatusCommand}"
                                           CommandParameter="{Binding .}" />
                            </SwipeItems>
                        </SwipeView.RightItems>

                        <Border Stroke="{StaticResource BorderColor}"
                                StrokeShape="RoundRectangle 16"
                                BackgroundColor="{StaticResource White}"
                                Padding="0">
                            <Border.Shadow>
                                <Shadow Brush="{StaticResource BlackBrush}" 
                                        Offset="0,2" 
                                        Opacity="0.06" 
                                        Radius="6"/>
                            </Border.Shadow>

                            <Grid ColumnDefinitions="120, *">
                                <!-- Image -->
                                <Border Grid.Column="0"
                                        StrokeThickness="0"
                                        StrokeShape="RoundRectangle 16,0,0,16">
                                    <Image Source="{Binding MainPhotoUrl}" 
                                           Aspect="AspectFill" 
                                           HeightRequest="110"
                                           BackgroundColor="{StaticResource Gray100}"/>
                                </Border>

                                <!-- Content -->
                                <VerticalStackLayout Grid.Column="1" 
                                                     Padding="14" 
                                                     Spacing="6"
                                                     VerticalOptions="Center">
                                    <Label Text="{Binding Title}" 
                                           Style="{StaticResource CardTitle}"
                                           LineBreakMode="TailTruncation"
                                           MaxLines="1"/>
                                    <Label Text="{Binding Price, StringFormat='{0:N0} PLN'}" 
                                           Style="{StaticResource PriceLabel}"/>

                                    <!-- Status Badge -->
                                    <Border Padding="10,4" 
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 6"
                                            HorizontalOptions="Start">
                                        <Border.Triggers>
                                            <DataTrigger TargetType="Border" Binding="{Binding Status}" Value="1">
                                                <Setter Property="IsVisible" Value="False"/>
                                            </DataTrigger>
                                            <DataTrigger TargetType="Border" Binding="{Binding Status}" Value="2">
                                                <Setter Property="BackgroundColor" Value="{StaticResource Danger}"/>
                                                <Setter Property="IsVisible" Value="True"/>
                                            </DataTrigger>
                                            <DataTrigger TargetType="Border" Binding="{Binding Status}" Value="3">
                                                <Setter Property="BackgroundColor" Value="{StaticResource Gray500}"/>
                                                <Setter Property="IsVisible" Value="True"/>
                                            </DataTrigger>
                                        </Border.Triggers>

                                        <Label TextColor="{StaticResource White}" 
                                               FontSize="11" 
                                               FontAttributes="Bold">
                                            <Label.Triggers>
                                                <DataTrigger TargetType="Label" Binding="{Binding Status}" Value="2">
                                                    <Setter Property="Text" Value="SPRZEDANE"/>
                                                </DataTrigger>
                                                <DataTrigger TargetType="Label" Binding="{Binding Status}" Value="3">
                                                    <Setter Property="Text" Value="ZARCHIWIZOWANE"/>
                                                </DataTrigger>
                                            </Label.Triggers>
                                        </Label>
                                    </Border>

                                    <Label Text="{Binding CreatedAt, StringFormat='Dodano: {0:dd.MM.yyyy}'}" 
                                           Style="{StaticResource MutedLabel}"/>
                                </VerticalStackLayout>
                            </Grid>
                        </Border>
                    </SwipeView>
                </DataTemplate>
            </CollectionView.ItemTemplate>

            <CollectionView.EmptyView>
                <VerticalStackLayout VerticalOptions="Center" 
                                     HorizontalOptions="Center"
                                     Spacing="16"
                                     Padding="40">
                    <Border StrokeShape="RoundRectangle 40"
                            StrokeThickness="0"
                            BackgroundColor="{StaticResource InfoLight}"
                            HeightRequest="80"
                            WidthRequest="80"
                            HorizontalOptions="Center">
                        <Label Text="📂" 
                               FontSize="36" 
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>
                    </Border>
                    <Label Text="Brak ogłoszeń" 
                           Style="{StaticResource SubHeadline}"
                           HorizontalOptions="Center"/>
                    <Label Text="Nie dodałeś jeszcze żadnych ogłoszeń. Kliknij '+' aby dodać swoje pierwsze ogłoszenie." 
                           Style="{StaticResource MutedLabel}"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center"/>
                </VerticalStackLayout>
            </CollectionView.EmptyView>
        </CollectionView>
    </Grid>
</ContentPage>