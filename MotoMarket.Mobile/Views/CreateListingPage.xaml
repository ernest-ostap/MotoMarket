<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:MotoMarket.Mobile.ViewModels"
             xmlns:model="clr-namespace:MotoMarket.Mobile.Models.Listings"
             x:Class="MotoMarket.Mobile.Views.CreateListingPage"
             Title="Dodaj ogłoszenie"
             BackgroundColor="{StaticResource BackgroundSecondary}">

    <ScrollView>
        <VerticalStackLayout Spacing="16" Padding="16">

            <!-- Header -->
            <Label Text="Nowe Ogłoszenie" 
                   Style="{StaticResource Headline}"
                   Margin="0,8,0,8"/>

            <!-- Photos Section -->
            <Frame Style="{StaticResource CardFrame}">
                <VerticalStackLayout Spacing="12">
                    <Label Text="Zdjęcia pojazdu" 
                           Style="{StaticResource SubHeadline}"/>
                    <Label Text="Dodaj zdjęcia swojego pojazdu (max. 10)" 
                           Style="{StaticResource MutedLabel}"/>

                    <Button Text="📷 Wybierz zdjęcia z galerii" 
                            Command="{Binding PickPhotosCommand}"
                            Style="{StaticResource InfoButton}"/>

                    <CollectionView ItemsSource="{Binding PhotosPreview}" 
                                    HeightRequest="120"
                                    ItemsLayout="HorizontalList">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border StrokeShape="RoundRectangle 12"
                                        StrokeThickness="0"
                                        Margin="0,0,10,0">
                                    <Image Source="{Binding .}" 
                                           Aspect="AspectFill" 
                                           WidthRequest="120" 
                                           HeightRequest="120"/>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                        <CollectionView.EmptyView>
                            <Border StrokeShape="RoundRectangle 12"
                                    Stroke="{StaticResource BorderColor}"
                                    BackgroundColor="{StaticResource Gray50}"
                                    HeightRequest="100"
                                    StrokeThickness="2"
                                    StrokeDashArray="4,4">
                                <Label Text="Brak wybranych zdjęć" 
                                       Style="{StaticResource MutedLabel}"
                                       HorizontalOptions="Center" 
                                       VerticalOptions="Center"/>
                            </Border>
                        </CollectionView.EmptyView>
                    </CollectionView>
                </VerticalStackLayout>
            </Frame>

            <!-- Basic Info Section -->
            <Frame Style="{StaticResource CardFrame}">
                <VerticalStackLayout Spacing="16">
                    <Label Text="Informacje podstawowe" 
                           Style="{StaticResource SubHeadline}"/>

                    <!-- Brand -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Marka *" 
                               Style="{StaticResource SecondaryLabel}"
                               FontAttributes="Bold"/>
                        <Border Stroke="{StaticResource BorderColor}" 
                                StrokeShape="RoundRectangle 12"
                                Padding="12,0">
                            <Picker Title="Wybierz markę"
                                    ItemsSource="{Binding Brands}"
                                    ItemDisplayBinding="{Binding Name}"
                                    SelectedItem="{Binding SelectedBrand}"
                                    BackgroundColor="Transparent"/>
                        </Border>
                    </VerticalStackLayout>

                    <!-- Model -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Model *" 
                               Style="{StaticResource SecondaryLabel}"
                               FontAttributes="Bold"/>
                        <Border Stroke="{StaticResource BorderColor}" 
                                StrokeShape="RoundRectangle 12"
                                Padding="12,0">
                            <Picker Title="Wybierz model"
                                    ItemsSource="{Binding Models}"
                                    ItemDisplayBinding="{Binding Name}"
                                    SelectedItem="{Binding SelectedModel}"
                                    BackgroundColor="Transparent"/>
                        </Border>
                    </VerticalStackLayout>

                    <!-- Title -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Tytuł ogłoszenia *" 
                               Style="{StaticResource SecondaryLabel}"
                               FontAttributes="Bold"/>
                        <Border Stroke="{StaticResource BorderColor}" 
                                StrokeShape="RoundRectangle 12"
                                Padding="12,0">
                            <Entry Placeholder="np. Audi A4 S-Line 2.0 TDI" 
                                   Text="{Binding Title}"
                                   BackgroundColor="Transparent"/>
                        </Border>
                    </VerticalStackLayout>

                    <!-- Description -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Opis *" 
                               Style="{StaticResource SecondaryLabel}"
                               FontAttributes="Bold"/>
                        <Border Stroke="{StaticResource BorderColor}" 
                                StrokeShape="RoundRectangle 12"
                                Padding="12">
                            <Editor Placeholder="Opisz swój pojazd szczegółowo..." 
                                    Text="{Binding Description}" 
                                    HeightRequest="120"
                                    BackgroundColor="Transparent"/>
                        </Border>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Frame>

            <!-- Technical Details Section -->
            <Frame Style="{StaticResource CardFrame}">
                <VerticalStackLayout Spacing="16">
                    <Label Text="Szczegóły techniczne" 
                           Style="{StaticResource SubHeadline}"/>

                    <Grid ColumnDefinitions="*,*" 
                          RowDefinitions="Auto,Auto,Auto" 
                          RowSpacing="16" 
                          ColumnSpacing="12">

                        <!-- Price -->
                        <VerticalStackLayout Grid.Row="0" Grid.Column="0" Spacing="6">
                            <Label Text="Cena (PLN) *" 
                                   Style="{StaticResource SecondaryLabel}"
                                   FontAttributes="Bold"/>
                            <Border Stroke="{StaticResource BorderColor}" 
                                    StrokeShape="RoundRectangle 12"
                                    Padding="12,0">
                                <Entry Keyboard="Numeric" 
                                       Text="{Binding Price}" 
                                       Placeholder="0"
                                       BackgroundColor="Transparent"/>
                            </Border>
                        </VerticalStackLayout>

                        <!-- Year -->
                        <VerticalStackLayout Grid.Row="0" Grid.Column="1" Spacing="6">
                            <Label Text="Rok produkcji *" 
                                   Style="{StaticResource SecondaryLabel}"
                                   FontAttributes="Bold"/>
                            <Border Stroke="{StaticResource BorderColor}" 
                                    StrokeShape="RoundRectangle 12"
                                    Padding="12,0">
                                <Entry Keyboard="Numeric" 
                                       Text="{Binding ProductionYear}" 
                                       Placeholder="2020"
                                       BackgroundColor="Transparent"/>
                            </Border>
                        </VerticalStackLayout>

                        <!-- Mileage -->
                        <VerticalStackLayout Grid.Row="1" Grid.Column="0" Spacing="6">
                            <Label Text="Przebieg (km) *" 
                                   Style="{StaticResource SecondaryLabel}"
                                   FontAttributes="Bold"/>
                            <Border Stroke="{StaticResource BorderColor}" 
                                    StrokeShape="RoundRectangle 12"
                                    Padding="12,0">
                                <Entry Keyboard="Numeric" 
                                       Text="{Binding Mileage}" 
                                       Placeholder="0"
                                       BackgroundColor="Transparent"/>
                            </Border>
                        </VerticalStackLayout>

                        <!-- VIN -->
                        <VerticalStackLayout Grid.Row="1" Grid.Column="1" Spacing="6">
                            <Label Text="VIN" 
                                   Style="{StaticResource SecondaryLabel}"
                                   FontAttributes="Bold"/>
                            <Border Stroke="{StaticResource BorderColor}" 
                                    StrokeShape="RoundRectangle 12"
                                    Padding="12,0">
                                <Entry Text="{Binding Vin}" 
                                       Placeholder="VIN"
                                       BackgroundColor="Transparent"/>
                            </Border>
                        </VerticalStackLayout>

                        <!-- City -->
                        <VerticalStackLayout Grid.Row="2" Grid.Column="0" Spacing="6">
                            <Label Text="Miasto" 
                                   Style="{StaticResource SecondaryLabel}"
                                   FontAttributes="Bold"/>
                            <Border Stroke="{StaticResource BorderColor}" 
                                    StrokeShape="RoundRectangle 12"
                                    Padding="12,0">
                                <Entry Text="{Binding City}" 
                                       Placeholder="Warszawa"
                                       BackgroundColor="Transparent"/>
                            </Border>
                        </VerticalStackLayout>

                        <!-- Region -->
                        <VerticalStackLayout Grid.Row="2" Grid.Column="1" Spacing="6">
                            <Label Text="Województwo" 
                                   Style="{StaticResource SecondaryLabel}"
                                   FontAttributes="Bold"/>
                            <Border Stroke="{StaticResource BorderColor}" 
                                    StrokeShape="RoundRectangle 12"
                                    Padding="12,0">
                                <Entry Text="{Binding Region}" 
                                       Placeholder="Mazowieckie"
                                       BackgroundColor="Transparent"/>
                            </Border>
                        </VerticalStackLayout>
                    </Grid>

                    <!-- Fuel Type -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Paliwo" 
                               Style="{StaticResource SecondaryLabel}"
                               FontAttributes="Bold"/>
                        <Border Stroke="{StaticResource BorderColor}" 
                                StrokeShape="RoundRectangle 12"
                                Padding="12,0">
                            <Picker ItemsSource="{Binding FuelTypes}" 
                                    ItemDisplayBinding="{Binding Name}" 
                                    SelectedItem="{Binding SelectedFuel}"
                                    BackgroundColor="Transparent"/>
                        </Border>
                    </VerticalStackLayout>

                    <!-- Gearbox -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Skrzynia biegów" 
                               Style="{StaticResource SecondaryLabel}"
                               FontAttributes="Bold"/>
                        <Border Stroke="{StaticResource BorderColor}" 
                                StrokeShape="RoundRectangle 12"
                                Padding="12,0">
                            <Picker ItemsSource="{Binding GearboxTypes}" 
                                    ItemDisplayBinding="{Binding Name}" 
                                    SelectedItem="{Binding SelectedGearbox}"
                                    BackgroundColor="Transparent"/>
                        </Border>
                    </VerticalStackLayout>

                    <!-- Body Type -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Nadwozie" 
                               Style="{StaticResource SecondaryLabel}"
                               FontAttributes="Bold"/>
                        <Border Stroke="{StaticResource BorderColor}" 
                                StrokeShape="RoundRectangle 12"
                                Padding="12,0">
                            <Picker ItemsSource="{Binding BodyTypes}" 
                                    ItemDisplayBinding="{Binding Name}" 
                                    SelectedItem="{Binding SelectedBody}"
                                    BackgroundColor="Transparent"/>
                        </Border>
                    </VerticalStackLayout>

                    <!-- Drive Type -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Napęd *" 
                               Style="{StaticResource SecondaryLabel}"
                               FontAttributes="Bold"/>
                        <Border Stroke="{StaticResource BorderColor}" 
                                StrokeShape="RoundRectangle 12"
                                Padding="12,0">
                            <Picker Title="Wybierz napęd"
                                    ItemsSource="{Binding DriveTypes}" 
                                    ItemDisplayBinding="{Binding Name}" 
                                    SelectedItem="{Binding SelectedDrive}"
                                    BackgroundColor="Transparent"/>
                        </Border>
                    </VerticalStackLayout>

                    <!-- Category -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Kategoria pojazdu *" 
                               Style="{StaticResource SecondaryLabel}"
                               FontAttributes="Bold"/>
                        <Border Stroke="{StaticResource BorderColor}" 
                                StrokeShape="RoundRectangle 12"
                                Padding="12,0">
                            <Picker Title="Wybierz kategorię"
                                    ItemsSource="{Binding Categories}" 
                                    ItemDisplayBinding="{Binding Name}" 
                                    SelectedItem="{Binding SelectedCategory}"
                                    BackgroundColor="Transparent"/>
                        </Border>
                    </VerticalStackLayout>
                    </VerticalStackLayout>
                </Frame>

            <!-- Parameters Section -->
            <Frame Style="{StaticResource CardFrame}">
                <VerticalStackLayout Spacing="16">
                    <Label Text="Parametry techniczne" 
                           Style="{StaticResource SubHeadline}"/>
                    <Label Text="Wprowadź dodatkowe parametry pojazdu (opcjonalnie)" 
                           Style="{StaticResource MutedLabel}"/>

                    <CollectionView ItemsSource="{Binding AvailableParameters}"
                                    SelectionMode="None">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <VerticalStackLayout Spacing="6" Margin="0,0,0,12">
                                    <Label Text="{Binding Name}" 
                                           Style="{StaticResource SecondaryLabel}"
                                           FontAttributes="Bold"/>
                                    <Grid ColumnDefinitions="*, Auto">
                                        <Border Grid.Column="0"
                                                Stroke="{StaticResource BorderColor}" 
                                                StrokeShape="RoundRectangle 12"
                                                Padding="12,0"
                                                Margin="0,0,8,0">
                                            <Entry Placeholder="{Binding Name}"
                                                   Text="{Binding Value}"
                                                   Keyboard="Default"
                                                   BackgroundColor="Transparent"/>
                                        </Border>
                                        <Label Grid.Column="1"
                                               Text="{Binding Unit}" 
                                               Style="{StaticResource MutedLabel}"
                                               VerticalOptions="Center"/>
                                    </Grid>
                                </VerticalStackLayout>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Frame>

            <!-- Features Section -->
            <Frame Style="{StaticResource CardFrame}">
                <VerticalStackLayout Spacing="16">
                    <Label Text="Wyposażenie" 
                           Style="{StaticResource SubHeadline}"/>
                    <Label Text="Zaznacz wyposażenie dostępne w pojeździe" 
                           Style="{StaticResource MutedLabel}"/>

                    <CollectionView ItemsSource="{Binding AvailableFeatures}"
                                    SelectionMode="None">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="Auto, *" 
                                      Padding="12,8"
                                      Margin="0,0,0,4">
                                    <CheckBox Grid.Column="0"
                                              IsChecked="{Binding IsSelected}"/>
                                    <Label Grid.Column="1"
                                           Text="{Binding Name}" 
                                           VerticalOptions="Center"
                                           Margin="12,0,0,0"/>
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Frame>

            <!-- Submit Button -->
            <Button Text="Dodaj ogłoszenie" 
                    Command="{Binding SubmitCommand}" 
                    Style="{StaticResource SuccessButton}"
                    HeightRequest="56"
                    Margin="0,8,0,24"/>

            <ActivityIndicator IsRunning="{Binding IsBusy}" 
                               IsVisible="{Binding IsBusy}"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>