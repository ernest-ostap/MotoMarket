<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:MotoMarket.Mobile.ViewModels"
             xmlns:model="clr-namespace:MotoMarket.Mobile.Models.Listings"
             x:Class="MotoMarket.Mobile.Views.CreateListingPage"
             Title="Dodaj ogłoszenie"
             BackgroundColor="#f8f9fa">

    <ScrollView>
        <VerticalStackLayout Spacing="20" Padding="20">

            <Label Text="Nowe Ogłoszenie" FontSize="24" FontAttributes="Bold" TextColor="#333"/>

            <Frame BorderColor="Transparent" CornerRadius="10" HasShadow="True" Padding="15">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Zdjęcia pojazdu" FontAttributes="Bold" TextColor="#666"/>

                    <Button Text="📷 Wybierz zdjęcia z galerii" 
                            Command="{Binding PickPhotosCommand}"
                            BackgroundColor="#0d6efd" 
                            TextColor="White"/>

                    <CollectionView ItemsSource="{Binding PhotosPreview}" 
                                    HeightRequest="120"
                                    ItemsLayout="HorizontalList">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Image Source="{Binding .}" 
                                       Aspect="AspectFill" 
                                       WidthRequest="120" 
                                       HeightRequest="120" 
                                       Margin="0,0,10,0"/>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                        <CollectionView.EmptyView>
                            <Label Text="Brak wybranych zdjęć" TextColor="Gray" HorizontalOptions="Center" VerticalOptions="Center" HeightRequest="50"/>
                        </CollectionView.EmptyView>
                    </CollectionView>
                </VerticalStackLayout>
            </Frame>

            <Frame BorderColor="Transparent" CornerRadius="10" HasShadow="True" Padding="15">
                <VerticalStackLayout Spacing="15">
                    <Label Text="Informacje podstawowe" FontAttributes="Bold" TextColor="#666"/>

                    <Label Text="Marka *" FontSize="12"/>
                    <Picker Title="Wybierz markę"
                            ItemsSource="{Binding Brands}"
                            ItemDisplayBinding="{Binding Name}"
                            SelectedItem="{Binding SelectedBrand}"
                            BackgroundColor="#f0f0f0"/>

                    <Label Text="Model *" FontSize="12"/>
                    <Picker Title="Wybierz model"
                            ItemsSource="{Binding Models}"
                            ItemDisplayBinding="{Binding Name}"
                            SelectedItem="{Binding SelectedModel}"
                            BackgroundColor="#f0f0f0"/>

                    <Label Text="Tytuł ogłoszenia *" FontSize="12"/>
                    <Entry Placeholder="np. Audi A4 S-Line" Text="{Binding Title}" BackgroundColor="#f0f0f0"/>

                    <Label Text="Opis *" FontSize="12"/>
                    <Editor Placeholder="Opisz swój pojazd..." 
                            Text="{Binding Description}" 
                            HeightRequest="100" 
                            BackgroundColor="#f0f0f0"/>
                </VerticalStackLayout>
            </Frame>

            <Frame BorderColor="Transparent" CornerRadius="10" HasShadow="True" Padding="15">
                <VerticalStackLayout Spacing="15">
                    <Label Text="Szczegóły techniczne" FontAttributes="Bold" TextColor="#666"/>

                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="15" ColumnSpacing="10">

                        <VerticalStackLayout Grid.Row="0" Grid.Column="0">
                            <Label Text="Cena (PLN) *" FontSize="12"/>
                            <Entry Keyboard="Numeric" Text="{Binding Price}" Placeholder="0" BackgroundColor="#f0f0f0"/>
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Row="0" Grid.Column="1">
                            <Label Text="Rok produkcji *" FontSize="12"/>
                            <Entry Keyboard="Numeric" Text="{Binding ProductionYear}" Placeholder="2020" BackgroundColor="#f0f0f0"/>
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Row="1" Grid.Column="0">
                            <Label Text="Przebieg (km) *" FontSize="12"/>
                            <Entry Keyboard="Numeric" Text="{Binding Mileage}" Placeholder="0" BackgroundColor="#f0f0f0"/>
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Row="1" Grid.Column="1">
                            <Label Text="VIN" FontSize="12"/>
                            <Entry Text="{Binding Vin}" Placeholder="VIN" BackgroundColor="#f0f0f0"/>
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Row="2" Grid.Column="0">
                            <Label Text="Miasto" FontSize="12"/>
                            <Entry Text="{Binding City}" Placeholder="Warszawa" BackgroundColor="#f0f0f0"/>
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Row="2" Grid.Column="1">
                            <Label Text="Województwo" FontSize="12"/>
                            <Entry Text="{Binding Region}" Placeholder="Mazowieckie" BackgroundColor="#f0f0f0"/>
                        </VerticalStackLayout>

                    </Grid>

                    <Label Text="Paliwo" FontSize="12"/>
                    <Picker ItemsSource="{Binding FuelTypes}" ItemDisplayBinding="{Binding Name}" SelectedItem="{Binding SelectedFuel}" BackgroundColor="#f0f0f0"/>

                    <Label Text="Skrzynia biegów" FontSize="12"/>
                    <Picker ItemsSource="{Binding GearboxTypes}" ItemDisplayBinding="{Binding Name}" SelectedItem="{Binding SelectedGearbox}" BackgroundColor="#f0f0f0"/>

                    <Label Text="Nadwozie" FontSize="12"/>
                    <Picker ItemsSource="{Binding BodyTypes}" ItemDisplayBinding="{Binding Name}" SelectedItem="{Binding SelectedBody}" BackgroundColor="#f0f0f0"/>

                    <Label Text="Napęd *" FontSize="12"/>
                    <Picker Title="Wybierz napęd"
                            ItemsSource="{Binding DriveTypes}" 
                            ItemDisplayBinding="{Binding Name}" 
                            SelectedItem="{Binding SelectedDrive}" 
                            BackgroundColor="#f0f0f0"/>

                    <Label Text="Kategoria pojazdu *" FontSize="12"/>
                    <Picker Title="Wybierz kategorię"
                            ItemsSource="{Binding Categories}" 
                            ItemDisplayBinding="{Binding Name}" 
                            SelectedItem="{Binding SelectedCategory}" 
                            BackgroundColor="#f0f0f0"/>

                </VerticalStackLayout>
            </Frame>

            <Button Text="Dodaj ogłoszenie" 
                    Command="{Binding SubmitCommand}" 
                    BackgroundColor="#198754" 
                    FontAttributes="Bold"
                    HeightRequest="50"
                    CornerRadius="25"
                    Margin="0,0,0,20"/>

            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" Color="Green"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>