<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MotoMarket.Mobile.Views.RegisterPage"
             Title="Rejestracja"
             BackgroundColor="{StaticResource BackgroundSecondary}">

    <ScrollView>
        <VerticalStackLayout Spacing="24" Padding="24" VerticalOptions="Start">

            <!-- Header -->
            <VerticalStackLayout Spacing="8" Margin="0,20,0,10">
                <Label Text="Załóż konto" 
                       Style="{StaticResource Headline}"
                       HorizontalOptions="Center"/>
                <Label Text="Dołącz do społeczności MotoMarket"
                       Style="{StaticResource SecondaryLabel}"
                       HorizontalOptions="Center"/>
            </VerticalStackLayout>

            <!-- Registration Form Card -->
            <Frame Style="{StaticResource CardFrame}" Padding="20">
                <VerticalStackLayout Spacing="16">
                    
                    <!-- Name Fields -->
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                        <VerticalStackLayout Spacing="6" Grid.Column="0">
                            <Label Text="Imię *" 
                                   Style="{StaticResource SecondaryLabel}"
                                   FontAttributes="Bold"/>
                            <Border Stroke="{StaticResource BorderColor}" 
                                    StrokeShape="RoundRectangle 12"
                                    Padding="12,0">
                                <Entry Placeholder="Jan" 
                                       Text="{Binding FirstName}"
                                       BackgroundColor="Transparent"/>
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="6" Grid.Column="1">
                            <Label Text="Nazwisko *" 
                                   Style="{StaticResource SecondaryLabel}"
                                   FontAttributes="Bold"/>
                            <Border Stroke="{StaticResource BorderColor}" 
                                    StrokeShape="RoundRectangle 12"
                                    Padding="12,0">
                                <Entry Placeholder="Kowalski" 
                                       Text="{Binding LastName}"
                                       BackgroundColor="Transparent"/>
                            </Border>
                        </VerticalStackLayout>
                    </Grid>

                    <!-- Phone -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Numer telefonu (opcjonalnie)" 
                               Style="{StaticResource SecondaryLabel}"
                               FontAttributes="Bold"/>
                        <Border Stroke="{StaticResource BorderColor}" 
                                StrokeShape="RoundRectangle 12"
                                Padding="12,0">
                            <Entry Placeholder="+48 123 456 789" 
                                   Text="{Binding PhoneNumber}" 
                                   Keyboard="Telephone"
                                   BackgroundColor="Transparent"/>
                        </Border>
                    </VerticalStackLayout>

                    <!-- Email -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Email *" 
                               Style="{StaticResource SecondaryLabel}"
                               FontAttributes="Bold"/>
                        <Border Stroke="{StaticResource BorderColor}" 
                                StrokeShape="RoundRectangle 12"
                                Padding="12,0">
                            <Entry Placeholder="jan.kowalski@email.com" 
                                   Text="{Binding Email}" 
                                   Keyboard="Email"
                                   BackgroundColor="Transparent"/>
                        </Border>
                    </VerticalStackLayout>

                    <!-- Password -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Hasło *" 
                               Style="{StaticResource SecondaryLabel}"
                               FontAttributes="Bold"/>
                        <Border Stroke="{StaticResource BorderColor}" 
                                StrokeShape="RoundRectangle 12"
                                Padding="12,0">
                            <Entry Placeholder="Minimum 6 znaków" 
                                   Text="{Binding Password}" 
                                   IsPassword="True"
                                   BackgroundColor="Transparent"/>
                        </Border>
                    </VerticalStackLayout>

                    <!-- Confirm Password -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Potwierdź hasło *" 
                               Style="{StaticResource SecondaryLabel}"
                               FontAttributes="Bold"/>
                        <Border Stroke="{StaticResource BorderColor}" 
                                StrokeShape="RoundRectangle 12"
                                Padding="12,0">
                            <Entry Placeholder="Powtórz hasło" 
                                   Text="{Binding ConfirmPassword}" 
                                   IsPassword="True"
                                   BackgroundColor="Transparent"/>
                        </Border>
                    </VerticalStackLayout>

                    <ActivityIndicator IsRunning="{Binding IsBusy}" 
                                       IsVisible="{Binding IsBusy}"/>

                    <Button Text="Zarejestruj się" 
                            Command="{Binding RegisterCommand}"
                            Style="{StaticResource SuccessButton}"
                            Margin="0,8,0,0"/>
                    
                </VerticalStackLayout>
            </Frame>

            <Label Text="* - pola wymagane" 
                   Style="{StaticResource MutedLabel}"
                   HorizontalOptions="Center"
                   Margin="0,0,0,20"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>