<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MotoMarket.Mobile.Views.RegisterPage"
             Title="Rejestracja">

    <ScrollView>
        <VerticalStackLayout Spacing="20" Padding="30" VerticalOptions="Center">

            <Label Text="Załóż konto" FontSize="28" FontAttributes="Bold" HorizontalOptions="Center"/>

            <Entry Placeholder="Imię" Text="{Binding FirstName}" />
            <Entry Placeholder="Nazwisko" Text="{Binding LastName}" />

            <Entry Placeholder="Numer telefonu (opcjonalnie)" 
                   Text="{Binding PhoneNumber}" 
                   Keyboard="Telephone" />

            <Entry Placeholder="Email" Text="{Binding Email}" Keyboard="Email" />
            <Entry Placeholder="Hasło" Text="{Binding Password}" IsPassword="True" />
            <Entry Placeholder="Potwierdź hasło" Text="{Binding ConfirmPassword}" IsPassword="True" />

            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" Color="Orange"/>

            <Button Text="Zarejestruj się" Command="{Binding RegisterCommand}" BackgroundColor="#ff6600"/>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>