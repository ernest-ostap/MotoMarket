<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:MotoMarket.Mobile.ViewModels"
             x:Class="MotoMarket.Mobile.Views.LoginPage"
             Title="Logowanie"
             BackgroundColor="{StaticResource BackgroundSecondary}">

    <ScrollView>
        <VerticalStackLayout Spacing="24" Padding="24" VerticalOptions="Center">
            
            <!-- Logo/Header -->
            <VerticalStackLayout Spacing="8" Margin="0,0,0,20">
                <Label Text="MotoMarket"
                       Style="{StaticResource Headline}"
                       TextColor="{StaticResource Primary}"
                       HorizontalOptions="Center"/>
                <Label Text="Zaloguj się do swojego konta"
                       Style="{StaticResource SecondaryLabel}"
                       HorizontalOptions="Center"/>
            </VerticalStackLayout>

            <!-- Login Form Card -->
            <Frame Style="{StaticResource CardFrame}" Padding="20">
                <VerticalStackLayout Spacing="16">
                    
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Email" 
                               Style="{StaticResource SecondaryLabel}"
                               FontAttributes="Bold"/>
                        <Border Stroke="{StaticResource BorderColor}" 
                                StrokeShape="RoundRectangle 12"
                                Padding="12,0">
                            <Entry Placeholder="Wpisz swój email"
                                   Text="{Binding Email}" 
                                   Keyboard="Email"
                                   BackgroundColor="Transparent"/>
                        </Border>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="6">
                        <Label Text="Hasło" 
                               Style="{StaticResource SecondaryLabel}"
                               FontAttributes="Bold"/>
                        <Border Stroke="{StaticResource BorderColor}" 
                                StrokeShape="RoundRectangle 12"
                                Padding="12,0">
                            <Entry Placeholder="Wpisz swoje hasło"
                                   Text="{Binding Password}"
                                   IsPassword="True"
                                   BackgroundColor="Transparent"/>
                        </Border>
                    </VerticalStackLayout>

                    <ActivityIndicator IsRunning="{Binding IsBusy}" 
                                       IsVisible="{Binding IsBusy}"/>

                    <Button Text="Zaloguj się"
                            Command="{Binding LoginCommand}"
                            Margin="0,8,0,0"/>
                    
                </VerticalStackLayout>
            </Frame>

            <!-- Register Link -->
            <HorizontalStackLayout HorizontalOptions="Center" Spacing="4">
                <Label Text="Nie masz konta?" 
                       Style="{StaticResource SecondaryLabel}"
                       VerticalOptions="Center"/>
                <Button Text="Załóż konto" 
                        Command="{Binding GoToRegisterCommand}" 
                        Style="{StaticResource GhostButton}"
                        Padding="8,0"/>
            </HorizontalStackLayout>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>