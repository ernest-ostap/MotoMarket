<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:MotoMarket.Mobile.ViewModels"
             xmlns:model="clr-namespace:MotoMarket.Mobile.Models.Listings"
             x:Class="MotoMarket.Mobile.Views.ListingsPage"
             Title="Ogłoszenia"
             BackgroundColor="{StaticResource BackgroundSecondary}">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Konto" Command="{Binding CheckProfileCommand}" />
    </ContentPage.ToolbarItems>

    <Grid RowDefinitions="Auto, Auto, *">

        <!-- Search Bar -->
        <Border Grid.Row="0" 
                Stroke="{StaticResource BorderColor}" 
                StrokeShape="RoundRectangle 12"
                BackgroundColor="{StaticResource White}"
                Margin="12,12,12,0"
                Padding="4">
            <Grid ColumnDefinitions="*, Auto">
                <SearchBar Placeholder="Szukaj auta..." 
                           Text="{Binding SearchText}"
                           SearchCommand="{Binding SearchCommand}"
                           BackgroundColor="Transparent"
                           Grid.Column="0"/>

                <Button Text="Filtry" 
                        Command="{Binding ToggleFiltersCommand}"
                        Style="{StaticResource SecondaryButton}"
                        Padding="16,8"
                        Margin="0,0,4,0"
                        Grid.Column="1"/>
            </Grid>
        </Border>

        <!-- Filters Panel -->
        <Frame Grid.Row="1" 
               IsVisible="{Binding AreFiltersVisible}" 
               BackgroundColor="{StaticResource White}"
               BorderColor="{StaticResource BorderColor}"
               CornerRadius="16"
               Margin="12,12,12,0"
               Padding="16">
            <VerticalStackLayout Spacing="16">

                <Label Text="Filtry wyszukiwania" 
                       Style="{StaticResource SubHeadline}"/>

                <!-- Price Range -->
                <VerticalStackLayout Spacing="6">
                    <Label Text="Cena (PLN)" 
                           Style="{StaticResource SecondaryLabel}"
                           FontAttributes="Bold"/>
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                        <Border Stroke="{StaticResource BorderColor}" 
                                StrokeShape="RoundRectangle 10"
                                Padding="12,0"
                                Grid.Column="0">
                            <Entry Placeholder="Min" 
                                   Text="{Binding MinPrice}" 
                                   Keyboard="Numeric"
                                   BackgroundColor="Transparent"/>
                        </Border>
                        <Border Stroke="{StaticResource BorderColor}" 
                                StrokeShape="RoundRectangle 10"
                                Padding="12,0"
                                Grid.Column="1">
                            <Entry Placeholder="Max" 
                                   Text="{Binding MaxPrice}" 
                                   Keyboard="Numeric"
                                   BackgroundColor="Transparent"/>
                        </Border>
                    </Grid>
                </VerticalStackLayout>

                <!-- Year -->
                <VerticalStackLayout Spacing="6">
                    <Label Text="Rok produkcji" 
                           Style="{StaticResource SecondaryLabel}"
                           FontAttributes="Bold"/>
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                        <Border Stroke="{StaticResource BorderColor}" 
                                StrokeShape="RoundRectangle 10"
                                Padding="12,0"
                                Grid.Column="0">
                            <Entry Placeholder="Od (np. 2015)" 
                                   Text="{Binding YearMin}" 
                                   Keyboard="Numeric"
                                   BackgroundColor="Transparent"/>
                        </Border>
                        <Border Stroke="{StaticResource BorderColor}" 
                                StrokeShape="RoundRectangle 10"
                                Padding="12,0"
                                Grid.Column="1">
                            <Entry Placeholder="Do (np. 2024)" 
                                   Text="{Binding YearMax}" 
                                   Keyboard="Numeric"
                                   BackgroundColor="Transparent"/>
                        </Border>
                    </Grid>
                </VerticalStackLayout>

                <!-- Brand -->
                <VerticalStackLayout Spacing="6">
                    <Label Text="Marka pojazdu" 
                           Style="{StaticResource SecondaryLabel}"
                           FontAttributes="Bold"/>
                    <Border Stroke="{StaticResource BorderColor}" 
                            StrokeShape="RoundRectangle 10"
                            Padding="12,0">
                        <Picker Title="Wybierz markę"
                                ItemsSource="{Binding Brands}"
                                ItemDisplayBinding="{Binding Name}"
                                SelectedItem="{Binding SelectedBrand}"
                                BackgroundColor="Transparent"/>
                    </Border>
                </VerticalStackLayout>

                <!-- Filter Buttons -->
                <Grid ColumnDefinitions="*, Auto" ColumnSpacing="12" Margin="0,8,0,0">
                    <Button Text="Szukaj" 
                            Command="{Binding SearchCommand}" 
                            Grid.Column="0"/>

                    <Button Text="Wyczyść" 
                            Command="{Binding ClearFiltersCommand}" 
                            Style="{StaticResource SecondaryButton}"
                            Grid.Column="1"/>
                </Grid>
            </VerticalStackLayout>
        </Frame>

        <!-- Loading Indicator -->
        <ActivityIndicator Grid.Row="2" 
                           IsRunning="{Binding IsBusy}" 
                           IsVisible="{Binding IsBusy}" 
                           HeightRequest="40"
                           VerticalOptions="Center"/>

        <!-- Listings Grid -->
        <CollectionView Grid.Row="2" 
                        ItemsSource="{Binding Listings}" 
                        Margin="12">
            <CollectionView.ItemsLayout>
                <GridItemsLayout Orientation="Vertical" 
                                 Span="2" 
                                 HorizontalItemSpacing="12" 
                                 VerticalItemSpacing="12"/>
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="model:ListingDto">
                    <Border Stroke="{StaticResource BorderColor}"
                            StrokeShape="RoundRectangle 16"
                            BackgroundColor="{StaticResource White}">
                        <Border.Shadow>
                            <Shadow Brush="{StaticResource BlackBrush}" 
                                    Offset="0,2" 
                                    Opacity="0.08" 
                                    Radius="8"/>
                        </Border.Shadow>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer 
                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ListingsViewModel}}, Path=GoToDetailsCommand}"
                                CommandParameter="{Binding .}" />
                        </Border.GestureRecognizers>

                        <Grid RowDefinitions="120, Auto">
                            <!-- Image -->
                            <Border Grid.Row="0" 
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 16,16,0,0">
                                <Image Source="{Binding MainPhotoUrl}" 
                                       Aspect="AspectFill" 
                                       BackgroundColor="{StaticResource Gray100}"/>
                            </Border>

                            <!-- Favorite Button -->
                            <Button Grid.Row="0"
                                    Text="❤"
                                    FontSize="16"
                                    BackgroundColor="{StaticResource White}" 
                                    TextColor="{StaticResource Gray400}"
                                    CornerRadius="20"
                                    HeightRequest="40"
                                    WidthRequest="40"
                                    HorizontalOptions="End"
                                    VerticalOptions="Start"
                                    Margin="8"
                                    Padding="0"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ListingsViewModel}}, Path=ToggleFavoriteCommand}"
                                    CommandParameter="{Binding .}">
                                <Button.Shadow>
                                    <Shadow Brush="{StaticResource BlackBrush}" 
                                            Offset="0,2" 
                                            Opacity="0.15" 
                                            Radius="4"/>
                                </Button.Shadow>
                                <Button.Triggers>
                                    <DataTrigger TargetType="Button" Binding="{Binding IsFavorite}" Value="True">
                                        <Setter Property="TextColor" Value="{StaticResource Primary}" />
                                        <Setter Property="BackgroundColor" Value="{StaticResource White}"/>
                                    </DataTrigger>
                                </Button.Triggers>
                            </Button>

                            <!-- Content -->
                            <VerticalStackLayout Grid.Row="1" Padding="12" Spacing="4">
                                <Label Text="{Binding Title}" 
                                       Style="{StaticResource CardTitle}"
                                       LineBreakMode="TailTruncation"
                                       MaxLines="1"/>
                                <Label Text="{Binding Price, StringFormat='{0:N0} PLN'}" 
                                       Style="{StaticResource PriceLabel}"/>
                                <Label Text="{Binding LocationCity}" 
                                       Style="{StaticResource MutedLabel}"/>
                            </VerticalStackLayout>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>

            <CollectionView.EmptyView>
                <VerticalStackLayout HorizontalOptions="Center" 
                                     VerticalOptions="Center" 
                                     Spacing="12"
                                     Padding="20">
                    <Label Text="🚗" FontSize="48" HorizontalOptions="Center"/>
                    <Label Text="Nie znaleziono ogłoszeń" 
                           Style="{StaticResource SubHeadline}"
                           HorizontalOptions="Center"/>
                    <Label Text="Spróbuj zmienić filtry wyszukiwania" 
                           Style="{StaticResource MutedLabel}"
                           HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </CollectionView.EmptyView>
        </CollectionView>
    </Grid>
</ContentPage>