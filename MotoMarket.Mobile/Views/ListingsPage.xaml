<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:MotoMarket.Mobile.ViewModels"
             xmlns:model="clr-namespace:MotoMarket.Mobile.Models.Listings"
             x:Class="MotoMarket.Mobile.Views.ListingsPage"
             Title="Ogłoszenia"
             BackgroundColor="#f0f0f0">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Konto" Command="{Binding CheckProfileCommand}" />
    </ContentPage.ToolbarItems>

    <Grid RowDefinitions="Auto, Auto, *">

        <Grid Grid.Row="0" ColumnDefinitions="*, Auto" Padding="10" BackgroundColor="White">
            <SearchBar Placeholder="Szukaj auta..." 
                       Text="{Binding SearchText}"
                       SearchCommand="{Binding SearchCommand}"
                       Grid.Column="0"/>

            <Button Text="Filtry" 
                    Command="{Binding ToggleFiltersCommand}"
                    BackgroundColor="Gray"
                    TextColor="White"
                    HeightRequest="40"
                    Margin="5,0,0,0"
                    Grid.Column="1"/>
        </Grid>

        <VerticalStackLayout Grid.Row="1" 
                             IsVisible="{Binding AreFiltersVisible}" 
                             Padding="15" 
                             Spacing="10"
                             BackgroundColor="#e9ecef">

            <Label Text="Cena (PLN):" FontAttributes="Bold" FontSize="12"/>
            <Grid ColumnDefinitions="*,*">
                <Entry Placeholder="Min" Text="{Binding MinPrice}" Keyboard="Numeric" Grid.Column="0" Margin="0,0,5,0" BackgroundColor="White"/>
                <Entry Placeholder="Max" Text="{Binding MaxPrice}" Keyboard="Numeric" Grid.Column="1" Margin="5,0,0,0" BackgroundColor="White"/>
            </Grid>

            <Label Text="Rok produkcji (od):" FontAttributes="Bold" FontSize="12"/>
            <Grid ColumnDefinitions="*,*">
                <Entry Placeholder="np. 2015" Text="{Binding YearMin}" Keyboard="Numeric" Grid.Column="0" Margin="0,0,5,0" BackgroundColor="White"/>
            </Grid>

            <Label Text="Marka pojazdu:" FontAttributes="Bold" FontSize="12"/>
            <Picker Title="Wybierz markę"
                    ItemsSource="{Binding Brands}"
                    ItemDisplayBinding="{Binding Name}"
                    SelectedItem="{Binding SelectedBrand}"
                    BackgroundColor="White" />

            <Grid ColumnDefinitions="*, Auto" Margin="0,10,0,0">
                <Button Text="Szukaj" Command="{Binding SearchCommand}" BackgroundColor="#ff6600" Grid.Column="0" Margin="0,0,5,0"/>

                <Button Text="❌" 
                        Command="{Binding ClearFiltersCommand}" 
                        BackgroundColor="Gray" 
                        Grid.Column="1"
                        WidthRequest="50"/>
            </Grid>
        </VerticalStackLayout>

        <ActivityIndicator Grid.Row="2" IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" Color="Orange" HeightRequest="40"/>

        <CollectionView Grid.Row="2" ItemsSource="{Binding Listings}" Margin="10">
            <CollectionView.ItemsLayout>
                <GridItemsLayout Orientation="Vertical" Span="2" HorizontalItemSpacing="10" VerticalItemSpacing="10"/>
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="model:ListingDto">
                    <Frame Padding="0" CornerRadius="10" HasShadow="True" BorderColor="Transparent" BackgroundColor="White" IsClippedToBounds="True">
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer 
                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ListingsViewModel}}, Path=GoToDetailsCommand}"
                                CommandParameter="{Binding .}" />
                        </Frame.GestureRecognizers>

                        <Grid RowDefinitions="120, Auto">
                            <Image Grid.Row="0" 
                                   Source="{Binding MainPhotoUrl}" 
                                   Aspect="AspectFill" 
                                   BackgroundColor="LightGray"/>

                            <Button Grid.Row="0"
                                    Text="❤"
                                    FontSize="18"
                                    BackgroundColor="#CCFFFFFF" 
                                    TextColor="Gray"
                                    CornerRadius="20"
                                    HeightRequest="40"
                                    WidthRequest="40"
                                    HorizontalOptions="End"
                                    VerticalOptions="Start"
                                    Margin="8"
                                    Padding="0"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ListingsViewModel}}, Path=ToggleFavoriteCommand}"
                                    CommandParameter="{Binding .}">
                                <Button.Shadow>
                                    <Shadow Brush="Black" Offset="2,2" Opacity="0.3" Radius="3"/>
                                </Button.Shadow>
                                <Button.Triggers>
                                    <DataTrigger TargetType="Button" Binding="{Binding IsFavorite}" Value="True">
                                        <Setter Property="TextColor" Value="Red" />
                                        <Setter Property="BackgroundColor" Value="White"/>
                                    </DataTrigger>
                                </Button.Triggers>
                            </Button>

                            <VerticalStackLayout Grid.Row="1" Padding="10">
                                <Label Text="{Binding Title}" FontAttributes="Bold" LineBreakMode="TailTruncation"/>
                                <Label Text="{Binding Price, StringFormat='{0:N0} PLN'}" TextColor="#ff6600" FontAttributes="Bold"/>
                                <Label Text="{Binding LocationCity}" FontSize="10" TextColor="Gray"/>
                            </VerticalStackLayout>
                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>