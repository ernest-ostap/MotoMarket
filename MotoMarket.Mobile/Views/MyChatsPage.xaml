<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MotoMarket.Mobile.Views.MyChatsPage"
             xmlns:vm="clr-namespace:MotoMarket.Mobile.ViewModels"
             Title="Wiadomości">

    <CollectionView ItemsSource="{Binding Conversations}">
        <CollectionView.ItemTemplate>
            <DataTemplate>
                <Frame Padding="15" Margin="5" HasShadow="True">
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:MyChatsViewModel}}, Path=OpenChatCommand}"
                                              CommandParameter="{Binding .}"/>
                    </Frame.GestureRecognizers>

                    <VerticalStackLayout>
                        <Label Text="{Binding DisplayName}" FontAttributes="Bold" FontSize="16"/>
                        <Label Text="{Binding LastMessage}" TextColor="Gray" LineBreakMode="TailTruncation"/>
                        <Label Text="{Binding SentAt, StringFormat='{0:dd.MM HH:mm}'}" FontSize="10" HorizontalOptions="End"/>
                    </VerticalStackLayout>
                </Frame>
            </DataTemplate>
        </CollectionView.ItemTemplate>
    </CollectionView>
</ContentPage>