<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MotoMarket.Mobile.Views.ChatPage"
             Title="Czat"
             Shell.TabBarIsVisible="False"
             BackgroundColor="{StaticResource BackgroundSecondary}">
    
    <Grid RowDefinitions="*, Auto">

        <!-- Messages List -->
        <CollectionView Grid.Row="0" 
                        ItemsSource="{Binding Messages}"
                        Margin="12,12,12,0">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="4,6">
                        <Border x:Name="MessageBubble"
                                StrokeThickness="0"
                                Padding="14,10"
                                MaximumWidthRequest="280">
                            
                            <Label Text="{Binding Content}" 
                                   TextColor="{StaticResource White}"
                                   FontSize="15"
                                   LineHeight="1.3"/>

                            <Border.Triggers>
                                <!-- My messages - right aligned, primary color -->
                                <DataTrigger TargetType="Border" Binding="{Binding IsMine}" Value="True">
                                    <Setter Property="HorizontalOptions" Value="End" />
                                    <Setter Property="BackgroundColor" Value="{StaticResource Primary}" />
                                    <Setter Property="StrokeShape" Value="RoundRectangle 16,16,4,16"/>
                                </DataTrigger>

                                <!-- Other messages - left aligned, secondary color -->
                                <DataTrigger TargetType="Border" Binding="{Binding IsMine}" Value="False">
                                    <Setter Property="HorizontalOptions" Value="Start" />
                                    <Setter Property="BackgroundColor" Value="{StaticResource Secondary}" />
                                    <Setter Property="StrokeShape" Value="RoundRectangle 16,16,16,4"/>
                                </DataTrigger>
                            </Border.Triggers>
                        </Border>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>

            <CollectionView.EmptyView>
                <VerticalStackLayout HorizontalOptions="Center" 
                                     VerticalOptions="Center"
                                     Spacing="12"
                                     Padding="40">
                    <Label Text="💬" FontSize="48" HorizontalOptions="Center"/>
                    <Label Text="Rozpocznij konwersację" 
                           Style="{StaticResource SubHeadline}"
                           HorizontalOptions="Center"/>
                    <Label Text="Napisz pierwszą wiadomość" 
                           Style="{StaticResource MutedLabel}"
                           HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </CollectionView.EmptyView>
        </CollectionView>

        <!-- Input Area -->
        <Border Grid.Row="1" 
                BackgroundColor="{StaticResource White}"
                StrokeThickness="0"
                Padding="12,12,12,16">
            <Border.Shadow>
                <Shadow Brush="{StaticResource BlackBrush}" 
                        Offset="0,-2" 
                        Opacity="0.06" 
                        Radius="8"/>
            </Border.Shadow>
            <Grid ColumnDefinitions="*, Auto" ColumnSpacing="12">
                <Border Grid.Column="0"
                        Stroke="{StaticResource BorderColor}" 
                        StrokeShape="RoundRectangle 24"
                        Padding="16,0">
                    <Entry Text="{Binding NewMessageText}" 
                           Placeholder="Napisz wiadomość..."
                           BackgroundColor="Transparent"/>
                </Border>

                <Button Text="➤" 
                        Command="{Binding SendCommand}" 
                        Grid.Column="1"
                        FontSize="18"
                        CornerRadius="24"
                        HeightRequest="48"
                        WidthRequest="48"
                        Padding="0"/>
            </Grid>
        </Border>
    </Grid>

</ContentPage>