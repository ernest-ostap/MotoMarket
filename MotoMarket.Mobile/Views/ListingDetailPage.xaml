<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MotoMarket.Mobile.Views.ListingDetailPage"
             Title="Szczegóły"
             BackgroundColor="{StaticResource BackgroundSecondary}">

    <Grid RowDefinitions="*, Auto">
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Spacing="0">

                <!-- Image Carousel -->
                <Grid HeightRequest="280">
                    <CarouselView ItemsSource="{Binding Photos}" 
                                  IndicatorView="indicatorView">
                        <CarouselView.ItemTemplate>
                            <DataTemplate>
                                <Image Source="{Binding .}" 
                                       Aspect="AspectFill"
                                       BackgroundColor="{StaticResource Gray100}"/>
                            </DataTemplate>
                        </CarouselView.ItemTemplate>
                    </CarouselView>

                    <!-- Favorite Button -->
                    <Button Text="❤"
                            FontSize="20"
                            TextColor="{StaticResource Gray400}"
                            BackgroundColor="{StaticResource White}"
                            CornerRadius="24"
                            HeightRequest="48"
                            WidthRequest="48"
                            Padding="0"
                            HorizontalOptions="End"
                            VerticalOptions="Start"
                            Margin="16"
                            Command="{Binding ToggleFavoriteCommand}">
                        <Button.Shadow>
                            <Shadow Brush="{StaticResource BlackBrush}" 
                                    Offset="0,2" 
                                    Opacity="0.15" 
                                    Radius="6"/>
                        </Button.Shadow>
                        <Button.Triggers>
                            <DataTrigger TargetType="Button" Binding="{Binding Listing.IsFavorite}" Value="True">
                                <Setter Property="TextColor" Value="{StaticResource Primary}" />
                            </DataTrigger>
                        </Button.Triggers>
                    </Button>

                    <!-- Page Indicator -->
                    <IndicatorView x:Name="indicatorView" 
                                   IndicatorColor="{StaticResource Gray300}"
                                   SelectedIndicatorColor="{StaticResource Primary}"
                                   HorizontalOptions="Center" 
                                   VerticalOptions="End"
                                   Margin="0,0,0,12"/>
                </Grid>

                <!-- Content -->
                <VerticalStackLayout Padding="20" Spacing="16">
                    
                    <!-- Title and Price -->
                    <VerticalStackLayout Spacing="8">
                        <Label Text="{Binding Listing.Title}" 
                               Style="{StaticResource Headline}"/>
                        <Label Text="{Binding Listing.Price, StringFormat='{0:N0} PLN'}" 
                               Style="{StaticResource PriceLabel}"
                               FontSize="26"/>
                    </VerticalStackLayout>

                    <!-- Location -->
                    <HorizontalStackLayout Spacing="6">
                        <Label Text="📍" FontSize="16"/>
                        <Label Text="{Binding Listing.LocationCity}" 
                               Style="{StaticResource SecondaryLabel}"
                               VerticalOptions="Center"/>
                    </HorizontalStackLayout>

                    <!-- Quick Info Card -->
                    <Frame BackgroundColor="{StaticResource BackgroundSecondary}" 
                           BorderColor="{StaticResource BorderColor}" 
                           CornerRadius="16" 
                           Padding="16">
                        <Grid ColumnDefinitions="*, *" 
                              RowDefinitions="Auto, Auto" 
                              RowSpacing="16"
                              ColumnSpacing="16">
                            <HorizontalStackLayout Grid.Row="0" Grid.Column="0" Spacing="8">
                                <Label Text="📅" FontSize="18"/>
                                <VerticalStackLayout>
                                    <Label Text="Rok" Style="{StaticResource MutedLabel}"/>
                                    <Label Text="{Binding Listing.ProductionYear}" FontAttributes="Bold"/>
                                </VerticalStackLayout>
                            </HorizontalStackLayout>

                            <HorizontalStackLayout Grid.Row="0" Grid.Column="1" Spacing="8">
                                <Label Text="🚗" FontSize="18"/>
                                <VerticalStackLayout>
                                    <Label Text="Przebieg" Style="{StaticResource MutedLabel}"/>
                                    <Label Text="{Binding Listing.Mileage, StringFormat='{0:N0} km'}" FontAttributes="Bold"/>
                                </VerticalStackLayout>
                            </HorizontalStackLayout>

                            <HorizontalStackLayout Grid.Row="1" Grid.Column="0" Spacing="8">
                                <Label Text="⛽" FontSize="18"/>
                                <VerticalStackLayout>
                                    <Label Text="Paliwo" Style="{StaticResource MutedLabel}"/>
                                    <Label Text="{Binding Listing.FuelType}" FontAttributes="Bold"/>
                                </VerticalStackLayout>
                            </HorizontalStackLayout>
                        </Grid>
                    </Frame>

                    <!-- Description -->
                    <VerticalStackLayout Spacing="12">
                        <Label Text="Opis pojazdu" 
                               Style="{StaticResource SubHeadline}"/>
                        <Label Text="{Binding Listing.Description}" 
                               Style="{StaticResource SecondaryLabel}"
                               LineHeight="1.4"/>
                    </VerticalStackLayout>

                    <!-- Seller Info -->
                    <Frame BackgroundColor="{StaticResource BackgroundSecondary}" 
                           BorderColor="{StaticResource BorderColor}" 
                           CornerRadius="16" 
                           Padding="16">
                        <HorizontalStackLayout Spacing="12">
                            <Border StrokeShape="RoundRectangle 24"
                                    StrokeThickness="0"
                                    BackgroundColor="{StaticResource Gray200}"
                                    HeightRequest="48"
                                    WidthRequest="48">
                                <Label Text="👤" 
                                       FontSize="24" 
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"/>
                            </Border>
                            <VerticalStackLayout VerticalOptions="Center">
                                <Label Text="Sprzedawca" Style="{StaticResource MutedLabel}"/>
                                <Label Text="{Binding Listing.SellerName}" 
                                       FontAttributes="Bold"
                                       FontSize="16"/>
                            </VerticalStackLayout>
                        </HorizontalStackLayout>
                    </Frame>

                    <ActivityIndicator IsRunning="{Binding IsBusy}" 
                                       IsVisible="{Binding IsBusy}"/>
                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>

        <!-- Bottom Action Bar -->
        <Border Grid.Row="1" 
                BackgroundColor="{StaticResource White}"
                StrokeThickness="0"
                Padding="16">
            <Border.Shadow>
                <Shadow Brush="{StaticResource BlackBrush}" 
                        Offset="0,-2" 
                        Opacity="0.08" 
                        Radius="10"/>
            </Border.Shadow>
            <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                <Button Text="📞 Zadzwoń" 
                        Grid.Column="0"
                        Command="{Binding CallSellerCommand}" 
                        Style="{StaticResource SuccessButton}"/>

                <Button Text="💬 Wiadomość" 
                        Grid.Column="1"
                        Command="{Binding OpenChatCommand}"
                        Style="{StaticResource InfoButton}"/>
            </Grid>
        </Border>
    </Grid>
</ContentPage>