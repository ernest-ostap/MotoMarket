<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:MotoMarket.Mobile.ViewModels"
             xmlns:model="clr-namespace:MotoMarket.Mobile.Models.Listings"
             x:Class="MotoMarket.Mobile.Views.FavoritesPage"
             Title="Moje Ulubione"
             BackgroundColor="{StaticResource BackgroundSecondary}">

    <Grid>
        <!-- Loading Indicator -->
        <ActivityIndicator IsRunning="{Binding IsBusy}" 
                           IsVisible="{Binding IsBusy}" 
                           HorizontalOptions="Center" 
                           VerticalOptions="Center"/>

        <!-- Favorites Grid -->
        <CollectionView ItemsSource="{Binding Favorites}" Margin="12">
            <CollectionView.ItemsLayout>
                <GridItemsLayout Orientation="Vertical" 
                                 Span="2" 
                                 HorizontalItemSpacing="12" 
                                 VerticalItemSpacing="12"/>
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="model:ListingDto">
                    <Border Stroke="{StaticResource BorderColor}"
                            StrokeShape="RoundRectangle 16"
                            BackgroundColor="{StaticResource White}">
                        <Border.Shadow>
                            <Shadow Brush="{StaticResource BlackBrush}" 
                                    Offset="0,2" 
                                    Opacity="0.08" 
                                    Radius="8"/>
                        </Border.Shadow>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:FavoritesViewModel}}, Path=GoToDetailsCommand}"
                                                  CommandParameter="{Binding .}" />
                        </Border.GestureRecognizers>

                        <Grid RowDefinitions="120, Auto">
                            <!-- Image -->
                            <Border Grid.Row="0" 
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 16,16,0,0">
                                <Image Source="{Binding MainPhotoUrl}" 
                                       Aspect="AspectFill" 
                                       BackgroundColor="{StaticResource Gray100}"/>
                            </Border>

                            <!-- Remove Button -->
                            <Button Grid.Row="0" 
                                    Text="🗑️" 
                                    FontSize="14"
                                    BackgroundColor="{StaticResource White}" 
                                    TextColor="{StaticResource Danger}"
                                    CornerRadius="20" 
                                    HeightRequest="40" 
                                    WidthRequest="40"
                                    HorizontalOptions="End" 
                                    VerticalOptions="Start" 
                                    Margin="8"
                                    Padding="0"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:FavoritesViewModel}}, Path=RemoveFavoriteCommand}"
                                    CommandParameter="{Binding .}">
                                <Button.Shadow>
                                    <Shadow Brush="{StaticResource BlackBrush}" 
                                            Offset="0,2" 
                                            Opacity="0.15" 
                                            Radius="4"/>
                                </Button.Shadow>
                            </Button>

                            <!-- Content -->
                            <VerticalStackLayout Grid.Row="1" Padding="12" Spacing="4">
                                <Label Text="{Binding Title}" 
                                       Style="{StaticResource CardTitle}"
                                       LineBreakMode="TailTruncation"
                                       MaxLines="1"/>
                                <Label Text="{Binding Price, StringFormat='{0:N0} PLN'}" 
                                       Style="{StaticResource PriceLabel}"/>
                                <Label Text="{Binding LocationCity}" 
                                       Style="{StaticResource MutedLabel}"/>
                            </VerticalStackLayout>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>

            <CollectionView.EmptyView>
                <VerticalStackLayout HorizontalOptions="Center" 
                                     VerticalOptions="Center" 
                                     Spacing="16"
                                     Padding="40">
                    <Border StrokeShape="RoundRectangle 40"
                            StrokeThickness="0"
                            BackgroundColor="{StaticResource DangerLight}"
                            HeightRequest="80"
                            WidthRequest="80"
                            HorizontalOptions="Center">
                        <Label Text="💔" 
                               FontSize="36" 
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>
                    </Border>
                    <Label Text="Brak ulubionych" 
                           Style="{StaticResource SubHeadline}"
                           HorizontalOptions="Center"/>
                    <Label Text="Nie masz jeszcze żadnych ulubionych ogłoszeń. Kliknij serduszko przy ogłoszeniu, aby je zapisać." 
                           Style="{StaticResource MutedLabel}"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center"/>
                </VerticalStackLayout>
            </CollectionView.EmptyView>
        </CollectionView>
    </Grid>
</ContentPage>